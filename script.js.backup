// Helper to generate a unique readable Order ID
function generateOrderId() {
    const now = new Date();
    // Format: DB-YYYYMMDD-XXXX (4 random digits)
    const dateStr = now.getFullYear().toString() +
        (now.getMonth() + 1).toString().padStart(2, '0') +
        now.getDate().toString().padStart(2, '0');
    const randomSuffix = Math.floor(1000 + Math.random() * 9000); // 1000-9999
    return `DB-${dateStr}-${randomSuffix}`;
}

// Rate Limiter
const RATE_LIMIT_MS = 30000; // 30 seconds
function isRateLimited(key) {
    const last = localStorage.getItem(`rl_${key}`);
    const now = Date.now();
    if (last && (now - last) < RATE_LIMIT_MS) return true;
    localStorage.setItem(`rl_${key}`, now);
    return false;
}

// Contact Form Logic
function handleContact(event) {
    if (event) event.preventDefault();
    if (isRateLimited('contact')) {
        alert("Bitte warten Sie einen Moment vor der nächsten Anfrage.");
        return;
    }

    // Bot detection: Submission too fast (< 3 seconds since section shown)
    const timeSinceShown = Date.now() - SECTION_STATS.contactShownAt;
    if (timeSinceShown < 3000) {
        console.warn("Bot suspected: Submission too fast.");
        SecurityMonitor.sendAlert('Bot-Verdacht', `Formular wurde in nur ${timeSinceShown}ms ausgefüllt.`);
        return;
    }

    // Honeypot check
    const hp = document.getElementById('hp_name').value;
    if (hp) {
        console.warn("Spam detected");
        SecurityMonitor.sendAlert('Bot-Angriff', 'Honeypot-Feld wurde ausgefüllt.');
        return;
    }

    const name = document.getElementById('contact-name').value;
    const email = document.getElementById('contact-email').value;
    const orderId = document.getElementById('contact-order-id').value;
    const message = document.getElementById('contact-message').value;
    const gdpr = document.getElementById('contact-gdpr').checked;

    if (!gdpr) {
        alert("Bitte akzeptieren Sie die Datenschutzerklärung.");
        return;
    }

    // Strict validation
    if (!name || name.trim().length < 2) {
        alert("Bitte geben Sie Ihren Namen ein.");
        return;
    }
    if (!email || !email.includes('@') || email.trim().length < 5) {
        alert("Bitte geben Sie eine gültige E-Mail-Adresse ein.");
        return;
    }

    // Strict Order ID Validation (Format: DB-YYYYMMDD-XXXX)
    const orderIdRegex = /^DB-\d{8}-\d{4}$/;
    if (!orderId || !orderIdRegex.test(orderId.trim())) {
        alert("Bitte geben Sie eine gültige Bestellnummer ein (Format: DB-YYYYMMDD-XXXX).");
        return;
    }

    if (!message || message.trim().length < 10) {
        alert("Bitte geben Sie eine Nachricht ein (mindestens 10 Zeichen).");
        return;
    }

    // Priority Check Logic
    const urgentKeywords = [
        'dringend', 'sofort', 'defekt', 'kaputt', 'beschwerde', 'problem', 'hilfe', 'eilig', 'wichtig', 'notfall',
        'reklamation', 'rückerstattung', 'stornierung', 'frist', 'deadline', 'fehler', 'falsch', 'nicht erhalten',
        'vermisst', 'beschädigt', 'kaput', 'geld zurück', 'schaden', 'anzeige', 'mahnung'
    ];
    const mediumKeywords = ['frage', 'bestellung', 'status', 'wann', 'angebot', 'termin', 'lieferzeit', 'versand'];

    let subject = "Anfrage über Webseite";
    const lowerMsg = message.toLowerCase();

    // Check for high priority
    const isUrgent = urgentKeywords.some(keyword => lowerMsg.includes(keyword));
    // Check for medium priority if not urgent
    const isMedium = !isUrgent && mediumKeywords.some(keyword => lowerMsg.includes(keyword));

    if (isUrgent) {
        subject = "[HOHE PRIORITÄT] " + subject;
    } else if (isMedium) {
        subject = "[MITTLERE PRIORITÄT] " + subject;
    }

    // Construct Email Body
    let bodyHeader = `Name: ${name}\nE-Mail: ${email}\n`;
    if (orderId && orderId.trim() !== "") {
        bodyHeader += `Bestellnummer: ${orderId}\n`;
    }

    let couponInfo = null;
    if (appliedCoupon) {
        const discount = getCouponDiscount();
        couponInfo = {
            code: appliedCoupon.code,
            discount: discount
        };
        bodyHeader += `Gutschein: ${appliedCoupon.code} (-${formatCurrency(discount)})\n`;
    }

    bodyHeader += `\n--------------------------------\n\n`;

    const body = bodyHeader + message;

    // Open mail client in a way that doesn't trigger navigation
    const mailtoLink = `mailto:druckbau@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

    // Create a hidden link and click it to avoid window.location issues
    const tempLink = document.createElement('a');
    tempLink.href = mailtoLink;
    tempLink.style.display = 'none';
    document.body.appendChild(tempLink);
    tempLink.click();
    document.body.removeChild(tempLink);

    // Log Order Internally (Admin Feature)
    if (typeof logOrder === 'function') {
        logOrder(name, email, orderId, message, couponInfo);
    }

    // Show success message instead of redirecting/reloading
    if (typeof showSuccess === 'function') {
        showSuccess("Ihr E-Mail-Programm wurde geöffnet. Bitte senden Sie die Nachricht ab!", 5000);
    } else {
        alert("Ihr E-Mail-Programm wurde geöffnet. Bitte senden Sie die Nachricht ab!");
    }

    // Formular NICHT automatisch zurücksetzen, damit der Nutzer die Daten behält
    // setTimeout(() => {
    //     document.querySelector('.contact-form').reset();
    // }, 8000);

    return false;
}

// --- SECURITY MONITORING SYSTEM ---
const SECURITY_CONFIG = {
    emailjs_public_key: 'YOUR_PUBLIC_KEY', // USER: Please replace with your EmailJS Public Key
    service_id: 'YOUR_SERVICE_ID',     // USER: Please replace with your EmailJS Service ID
    template_id: 'YOUR_TEMPLATE_ID'    // USER: Please replace with your EmailJS Template ID
};

const SecurityMonitor = {
    init: function () {
        if (typeof emailjs !== 'undefined') {
            emailjs.init(SECURITY_CONFIG.emailjs_public_key);
        }

        // Listen for CSP Violations
        document.addEventListener('securitypolicyviolation', (e) => {
            console.error('CSP Violation detected:', e);
            this.sendAlert('CSP-Verstoß', `Quelle: ${e.blockedURI}, Typ: ${e.violatedDirective}`);
        });

        // Periodic Check for DOM Manipulations (Basic check)
        this.startAuditLoop();
        console.log('Security Monitor active.');
    },

    sendAlert: function (incident, details) {
        if (!SECURITY_CONFIG.emailjs_public_key || SECURITY_CONFIG.emailjs_public_key.startsWith('YOUR_')) {
            console.warn(`[SECURITY ALERT] ${incident}: ${details} (EmailJS not configured)`);
            return;
        }

        const templateParams = {
            incident: incident,
            details: details,
            timestamp: new Date().toLocaleString(),
            url: window.location.href
        };

        emailjs.send(SECURITY_CONFIG.service_id, SECURITY_CONFIG.template_id, templateParams)
            .then(() => console.log('Security alert sent via email.'))
            .catch((error) => console.error('Failed to send security alert:', error));
    },

    startAuditLoop: function () {
        // Observer for suspicious DOM changes in the footer or hidden fields
        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.type === 'childList' || mutation.type === 'attributes') {
                    // Check if honeypot was tampered with (unhidden)
                    const hp = document.querySelector('.hp-field');
                    if (hp && window.getComputedStyle(hp).display !== 'none') {
                        this.sendAlert('Manipulation erkannt', 'Honeypot-Feld wurde sichtbar gemacht oder manipuliert.');
                        observer.disconnect();
                    }
                }
            });
        });

        observer.observe(document.body, { attributes: true, childList: true, subtree: true });
    }
};
// Initialize on load is enough, avoid double calls
// init() at end of file will handle it
document.addEventListener('DOMContentLoaded', () => {
    // init(); // Removed to avoid double execution
    SecurityMonitor.init();
});

// Event Delegation: Products & Cart
document.body.addEventListener('click', (e) => {
    // Add to Cart
    if (e.target.classList.contains('add-to-cart-btn')) {
        addToCart(e.target.getAttribute('data-id'));
    }
    // Add Custom to Cart
    if (e.target.classList.contains('add-custom-btn')) {
        addCustomToCart(e.target.getAttribute('data-id'));
    }
    // Maximize Icon Stop Propagation
    if (e.target.closest('.maximize-icon')) {
        e.stopPropagation();
    }
    // Remove from Cart
    const removeBtn = e.target.closest('.remove-btn');
    if (removeBtn) {
        removeFromCart(parseInt(removeBtn.getAttribute('data-index')));
    }
    // Checkout
    if (e.target.id === 'checkout-btn') {
        checkout();
    }
    // Gallery Close
    if (e.target.id === 'close-gallery-btn') {
        e.preventDefault();
        window.close();
    }
    // Rate Product
    if (e.target.classList.contains('rate-btn')) {
        const id = e.target.getAttribute('data-id');
        const name = e.target.getAttribute('data-name');
        if (window.openRateModal) {
            window.openRateModal(id, name);
        } else {
            console.error('openRateModal not found');
        }
    }
    // View Reviews
    if (e.target.classList.contains('view-reviews-btn')) {
        const id = e.target.getAttribute('data-id');
        const name = e.target.getAttribute('data-name');
        if (window.openViewReviewsModal) {
            window.openViewReviewsModal(id, name);
        }
    }
    // Delete Review
    if (e.target.classList.contains('delete-review-btn')) {
        const productId = e.target.getAttribute('data-product-id');
        const index = parseInt(e.target.getAttribute('data-index'));
        const isOwner = e.target.getAttribute('data-is-owner') === 'true';

        deleteReviewInternal(productId, index, isOwner);
    }
});

// Event Delegation: Color Previews
document.body.addEventListener('change', (e) => {
    if (e.target.classList.contains('color-select')) {
        updateColorPreview(e.target, e.target.getAttribute('data-id'));
    }

    // Update file list preview
    if (e.target.classList.contains('file-input-trigger')) {
        const id = e.target.getAttribute('data-id');
        const list = document.getElementById(`file-list-${id}`);
        const files = e.target.files;
        if (list) {
            list.innerHTML = '';
            if (files.length > 0) {
                Array.from(files).forEach((file, index) => {
                    const li = document.createElement('li');
                    li.innerHTML = `
                            <span>${file.name}</span>
                            <button type="button" class="remove-file-btn" data-index="${index}" data-id="${id}" title="Entfernen">&times;</button>
                        `;
                    list.appendChild(li);
                });
            }
        }
    }
});

// Click handler for removing files (Event Delegation)
document.addEventListener('click', (e) => {
    if (e.target.classList.contains('remove-file-btn')) {
        const index = parseInt(e.target.getAttribute('data-index'));
        const id = e.target.getAttribute('data-id');
        const fileInput = document.getElementById(`custom-files-${id}`);

        if (fileInput && fileInput.files) {
            const dt = new DataTransfer();
            const { files } = fileInput;

            for (let i = 0; i < files.length; i++) {
                if (i !== index) dt.items.add(files[i]);
            }

            fileInput.files = dt.files;
            // Trigger change event to refresh the list
            fileInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
    }
});

