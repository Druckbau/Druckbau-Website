const SHIPPING_COST = 4.90;

// Escape HTML utility to prevent XSS and ReferenceErrors
function escapeHtml(text) {
    if (typeof text !== 'string') return text;
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// Helper for safe JSON parsing
function safeJSONParse(key, fallback) {
    try {
        const item = localStorage.getItem(key);
        return item ? JSON.parse(item) : fallback;
    } catch (e) {
        console.error(`Error parsing localStorage key "${key}":`, e);
        return fallback;
    }
}

// Resilient initialization wrapper
function resilientInit(fn, name) {
    try {
        fn();
    } catch (e) {
        console.error(`Initialization error in ${name || 'unknown'}:`, e);
    }
}

// Initializes the application
function init() {
    // ALWAYS setup navigation first, as early as possible
    resilientInit(setupNavigation, "setupNavigation");

    resilientInit(initTheme, "initTheme");

    // Check if we are on the gallery page
    if (document.getElementById('gallery-app')) {
        resilientInit(loadGallery, "loadGallery");
        return;
    }

    // Normal page initialization
    if (document.getElementById('products-grid')) {
        resilientInit(loadCartFromStorage, "loadCartFromStorage");
        resilientInit(loadWishlistFromStorage, "loadWishlistFromStorage");
        resilientInit(renderProducts, "renderProducts");
        resilientInit(updateCartIcon, "updateCartIcon");
        resilientInit(updateWishlistIcon, "updateWishlistIcon");
        resilientInit(initFAQ, "initFAQ");
        resilientInit(initOrderStatusChecker, "initOrderStatusChecker");
        resilientInit(initNewsletterSystem, "initNewsletterSystem");
        resilientInit(initUrgencyNotifications, "initUrgencyNotifications");
    }
    resilientInit(initCookieBanner, "initCookieBanner");

    // Initialize new features
    resilientInit(initNewFeatures, "initNewFeatures");
    resilientInit(attachEventListeners, "attachEventListeners");
}

function attachEventListeners() {
    document.body.addEventListener('click', (e) => {
        const target = e.target;

        // Checkout Modal Navigation
        if (target.closest('#close-checkout') || target.closest('.close-modal')) {
            if (target.closest('#checkout-modal')) {
                closeCheckoutModal();
            }
        }

        // Buttons with specific ids or classes (robust for internationalization)
        if (target.id === 'final-checkout-btn' || target.closest('#final-checkout-btn')) {
            console.log('Final checkout button triggered via ID');
            submitCheckout();
            return; // Exit delegation for this hit
        }

        if (target.closest('.contact-btn')) {
            const btn = target.closest('.contact-btn');
            const text = btn.innerText.toLowerCase();

            if (text.includes('weiter') || text.includes('next')) {
                nextCheckoutStep();
            } else if (text === 'zurück' || text === 'back') {
                prevCheckoutStep();
            }
        }

        if (target.id === 'checkout-btn') {
            checkout();
        }

        // Chat
        if (target.closest('#chat-toggle')) {
            toggleChat();
        }
        if (target.closest('.chat-close-btn')) {
            toggleChat();
        }
        if (target.closest('.chat-send-btn')) {
            sendChatMessage();
        }
        if (target.classList.contains('quick-reply-btn')) {
            const topic = target.getAttribute('data-topic') || target.innerText.replace(/[^\w\s]/g, '').trim();
            sendQuickReply(topic);
        }

        // Language Switcher
        if (target.classList.contains('lang-btn') || target.closest('.lang-btn')) {
            const btn = target.classList.contains('lang-btn') ? target : target.closest('.lang-btn');
            const lang = btn.getAttribute('data-lang');
            if (lang && typeof window.switchLanguage === 'function') {
                window.switchLanguage(lang);

                // Update active button UI
                document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            }
        }

        // Admin (delegated)
        if (target.innerText.includes('Export') && target.classList.contains('contact-btn')) {
            exportOrdersToCSV();
        }
        if (target.innerText.includes('Angebot') && target.classList.contains('contact-btn')) {
            createSeasonalOffer();
        }

        // Remove from cart (delegated for dynamic items)
        const removeBtn = target.closest('.remove-btn');
        if (removeBtn && removeBtn.hasAttribute('data-index')) {
            removeFromCart(parseInt(removeBtn.getAttribute('data-index')));
        }
    });

    const chatInput = document.getElementById('chat-input');
    if (chatInput) {
        chatInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                sendChatMessage();
            }
        });
    }
}

// Toast Notification System
function showToast(message, type = 'info', duration = 4000) {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = `toast ${type}`;

    const icons = {
        success: '✓',
        error: '✕',
        warning: '⚠',
        info: 'ℹ'
    };

    toast.innerHTML = `
        <div class="toast-icon">${icons[type] || icons.info}</div>
        <div class="toast-content">${message}</div>
        <button class="toast-close" onclick="this.parentElement.remove()">×</button>
    `;

    container.appendChild(toast);

    // Auto-remove after duration
    if (duration > 0) {
        setTimeout(() => {
            toast.classList.add('removing');
            setTimeout(() => toast.remove(), 300);
        }, duration);
    }
}

// Convenience functions
function showSuccess(message, duration) {
    showToast(message, 'success', duration);
}

function showError(message, duration) {
    showToast(message, 'error', duration);
}

function showWarning(message, duration) {
    showToast(message, 'warning', duration);
}

function showInfo(message, duration) {
    showToast(message, 'info', duration);
}

// Chat Widget System
const chatFAQ = {
    'Lieferzeit': 'Unsere Standard-Lieferzeit beträgt 3-5 Werktage. Express-Versand ist auf Anfrage möglich! 🚚',
    'Preise': 'Unsere Preise variieren je nach Produkt und Menge. Schauen Sie sich unsere Produktseite an oder kontaktieren Sie uns für ein individuelles Angebot! 💰',
    'Materialien': 'Wir verwenden hochwertige Materialien wie PLA, PETG, ABS und TPU. Jedes Material hat seine eigenen Eigenschaften - fragen Sie uns gerne! 🎨',
    'Kontakt': 'Sie erreichen uns per E-Mail unter druckbau.info@gmail.com oder nutzen Sie unser Kontaktformular. Wir antworten innerhalb von 24 Stunden! 📞',
    'Versand': 'Wir versenden deutschlandweit für 4,90€. Ab 50€ Bestellwert ist der Versand kostenlos! 📦',
    'Zahlung': 'Aktuell bieten wir Zahlung per Überweisung an. Nach Bestelleingang erhalten Sie unsere Bankdaten per E-Mail. 💳',
    'Rückgabe': 'Individuelle 3D-Drucke sind vom Umtausch ausgeschlossen. Bei Mängeln kontaktieren Sie uns bitte innerhalb von 14 Tagen. 🔄'
};

function toggleChat() {
    const chatWindow = document.getElementById('chat-window');
    const chatBadge = document.getElementById('chat-badge');

    if (chatWindow.style.display === 'none') {
        chatWindow.style.display = 'flex';
        chatBadge.style.display = 'none';
        scrollChatToBottom();
    } else {
        chatWindow.style.display = 'none';
    }
}

function sendChatMessage() {
    const input = document.getElementById('chat-input');
    const message = input.value.trim();

    if (!message) return;

    addChatMessage(message, 'user');
    input.value = '';

    // Simulate bot response
    setTimeout(() => {
        const response = getBotResponse(message);
        addChatMessage(response, 'bot');
    }, 500);
}

function sendQuickReply(topic) {
    addChatMessage(topic, 'user');

    setTimeout(() => {
        // Look up translated response based on topic/key
        const responseKey = `chat_reply_${topic.toLowerCase()}_response`;
        const response = (typeof t === 'function' ? t(responseKey) : null) || 'Entschuldigung, dazu habe ich keine Information. Bitte kontaktieren Sie uns direkt!';
        addChatMessage(response, 'bot');
    }, 500);
}

function addChatMessage(text, sender) {
    const messagesContainer = document.getElementById('chat-messages');
    const messageDiv = document.createElement('div');
    messageDiv.className = `chat-message ${sender}`;

    const avatar = sender === 'bot' ? '🤖' : '👤';

    messageDiv.innerHTML = `
        <div class="chat-avatar">${avatar}</div>
        <div class="chat-bubble">${text}</div>
    `;

    messagesContainer.appendChild(messageDiv);
    scrollChatToBottom();
}

function getBotResponse(message) {
    const lowerMessage = message.toLowerCase();

    // Simple keyword matching
    if (lowerMessage.includes('liefer') || lowerMessage.includes('dauer') || lowerMessage.includes('schnell')) {
        return chatFAQ['Lieferzeit'];
    } else if (lowerMessage.includes('preis') || lowerMessage.includes('kosten') || lowerMessage.includes('euro')) {
        return chatFAQ['Preise'];
    } else if (lowerMessage.includes('material') || lowerMessage.includes('pla') || lowerMessage.includes('petg')) {
        return chatFAQ['Materialien'];
    } else if (lowerMessage.includes('kontakt') || lowerMessage.includes('email') || lowerMessage.includes('telefon')) {
        return chatFAQ['Kontakt'];
    } else if (lowerMessage.includes('versand') || lowerMessage.includes('shipping')) {
        return chatFAQ['Versand'];
    } else if (lowerMessage.includes('zahlung') || lowerMessage.includes('bezahl')) {
        return chatFAQ['Zahlung'];
    } else if (lowerMessage.includes('rückgabe') || lowerMessage.includes('umtausch') || lowerMessage.includes('reklamation')) {
        return chatFAQ['Rückgabe'];
    } else if (lowerMessage.includes('hallo') || lowerMessage.includes('hi') || lowerMessage.includes('hey')) {
        return 'Hallo! 👋 Wie kann ich Ihnen helfen? Nutzen Sie gerne die Quick-Reply-Buttons unten!';
    } else {
        return 'Danke für Ihre Nachricht! Für spezifische Fragen kontaktieren Sie uns bitte direkt unter druckbau.info@gmail.com oder nutzen Sie unser Kontaktformular. 📧';
    }
}

function scrollChatToBottom() {
    const messagesContainer = document.getElementById('chat-messages');
    if (messagesContainer) {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }
}

// Social Proof & Urgency System
function showUrgencyNotification(productName, location, minutesAgo) {
    const container = document.getElementById('urgency-notifications');
    if (!container) return;

    const notification = document.createElement('div');
    notification.className = 'urgency-notification';

    notification.innerHTML = `
        <div class="urgency-icon">🔥</div>
        <div class="urgency-content">
            <div class="urgency-title">${productName}</div>
            <div class="urgency-text">Vor ${minutesAgo} Min. in ${location} gekauft</div>
        </div>
    `;

    container.appendChild(notification);

    // Auto-remove after 5 seconds
    setTimeout(() => {
        notification.classList.add('removing');
        setTimeout(() => notification.remove(), 300);
    }, 5000);
}

function initUrgencyNotifications() {
    const locations = ['Berlin', 'München', 'Hamburg', 'Köln', 'Frankfurt', 'Stuttgart', 'Düsseldorf', 'Leipzig'];
    const productNames = products.filter(p => !p.isCustom).map(p => p.name);

    // Show first notification after 5 seconds
    setTimeout(() => {
        const randomProduct = productNames[Math.floor(Math.random() * productNames.length)];
        const randomLocation = locations[Math.floor(Math.random() * locations.length)];
        const randomMinutes = Math.floor(Math.random() * 45) + 5;

        showUrgencyNotification(randomProduct, randomLocation, randomMinutes);
    }, 5000);

    // Show notifications every 20-40 seconds
    setInterval(() => {
        const randomProduct = productNames[Math.floor(Math.random() * productNames.length)];
        const randomLocation = locations[Math.floor(Math.random() * locations.length)];
        const randomMinutes = Math.floor(Math.random() * 45) + 5;

        showUrgencyNotification(randomProduct, randomLocation, randomMinutes);
    }, 30000); // Every 30 seconds
}

// Order Status Checker Logic
function initOrderStatusChecker() {
    const btn = document.getElementById('check-status-btn');
    const input = document.getElementById('status-order-id');
    const resultDiv = document.getElementById('status-result');
    const badge = document.getElementById('status-badge');

    if (!btn || !input) return;

    btn.addEventListener('click', () => {
        let orderId = input.value.trim();
        if (!orderId) {
            showError("Bitte geben Sie eine Bestellnummer ein.");
            return;
        }

        // Clean ID (strip # if present)
        const cleanId = orderId.replace('#', '').toUpperCase();

        const orders = safeJSONParse('druckbau_orders', []);
        const order = orders.find(o => o.orderId === cleanId);

        resultDiv.style.display = 'block';
        if (order) {
            const status = order.status || 'Eingegangen';
            badge.textContent = status;

            // Coloring
            if (status === 'Eingegangen') {
                badge.style.background = '#e9ecef';
                badge.style.color = '#495057';
            } else if (status === 'In Bearbeitung') {
                badge.style.background = '#fff3cd';
                badge.style.color = '#856404';
            } else if (status === 'Gedruckt') {
                badge.style.background = '#d1ecf1';
                badge.style.color = '#0c5460';
            } else if (status === 'Versendet') {
                badge.style.background = '#d4edda';
                badge.style.color = '#155724';
            }
        } else {
            badge.textContent = "Nicht gefunden";
            badge.style.background = '#f8d7da';
            badge.style.color = '#721c24';
        }
    });
}

// Cookie Banner Logic
function initCookieBanner() {
    const overlay = document.getElementById('cookie-overlay');

    // Debugging: Log if element is found
    if (!overlay) {
        console.warn('Cookie overlay element not found');
        return;
    }

    // Check session storage (persists on reload, clears on close)
    if (!sessionStorage.getItem('cookiesAccepted_session')) {
        console.log('Showing cookie banner (New Session)');
        overlay.classList.add('show');
        document.body.style.overflow = 'hidden';
    }

    const acceptBtn = document.getElementById('accept-cookies');
    if (acceptBtn) {
        acceptBtn.addEventListener('click', () => {
            console.log('Cookies accepted by user');
            sessionStorage.setItem('cookiesAccepted_session', 'true');
            overlay.classList.remove('show');
            document.body.style.overflow = '';
        });
    }

    const declineBtn = document.getElementById('decline-cookies');
    if (declineBtn) {
        declineBtn.addEventListener('click', () => {
            console.log('Cookies declined by user');
            overlay.classList.remove('show');
            document.body.style.overflow = '';
        });
    }
}

// Persistence Helpers
function saveCartToStorage() {
    localStorage.setItem('druckbau_cart', JSON.stringify(cart));
}

function loadCartFromStorage() {
    const saved = localStorage.getItem('druckbau_cart');
    if (saved) {
        try {
            cart = JSON.parse(saved);
        } catch (e) {
            console.error('Failed to load cart', e);
            cart = [];
        }
    }
}

// FAQ Accordion
function initFAQ() {
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        const question = item.querySelector('.faq-question');
        if (question) {
            question.addEventListener('click', () => {
                const isActive = item.classList.contains('active');
                faqItems.forEach(i => i.classList.remove('active'));
                if (!isActive) item.classList.add('active');
            });
        }
    });
}

// Theme Management
function initTheme() {
    const themeToggle = document.getElementById('theme-toggle');
    if (!themeToggle) return;

    const currentTheme = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', currentTheme);
    updateThemeIcon(currentTheme);

    themeToggle.addEventListener('click', () => {
        const theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        updateThemeIcon(theme);
    });
}

function updateThemeIcon(theme) {
    const sunIcon = document.querySelector('.sun-icon');
    const moonIcon = document.querySelector('.moon-icon');
    if (!sunIcon || !moonIcon) return;

    if (theme === 'dark') {
        sunIcon.style.display = 'none';
        moonIcon.style.display = 'block';
    } else {
        sunIcon.style.display = 'block';
        moonIcon.style.display = 'none';
    }
}

// Gallery Standalone Logic
function loadGallery() {
    const params = new URLSearchParams(window.location.search);
    const productId = params.get('id');
    const startImg = params.get('img');

    const product = products.find(p => p.id === productId);

    if (!product || !product.images) {
        document.body.innerHTML = '<h1 style="color:white; text-align:center;">Produkt nicht gefunden</h1>';
        return;
    }

    const titleElement = document.getElementById('product-title');
    if (titleElement) titleElement.innerText = product.name;

    const mainImg = document.getElementById('main-display');
    const thumbsContainer = document.getElementById('thumbs-container');

    // Set initial image
    let currentImg = startImg || product.images[0];
    if (mainImg) mainImg.src = currentImg;

    // Render thumbnails
    if (thumbsContainer) {
        thumbsContainer.innerHTML = product.images.map(img => `
            <img src="${img}" class="thumbnail ${img === currentImg ? 'active' : ''}" data-src="${img}">
        `).join('');
    }
}

function switchGalleryImage(src, thumb) {
    const mainImg = document.getElementById('main-display');
    if (mainImg) mainImg.src = src;
    document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
    if (thumb) thumb.classList.add('active');
}

// Render Products to DOM
// Render Products to DOM
function renderProducts() {
    const grid = document.getElementById('products-grid');
    grid.innerHTML = products.map(product => {
        const isWishlisted = wishlist.includes(product.id);

        // Shared Rating Logic
        let avgRating = 0;
        let reviewCount = 0;
        let starsDisplay = '☆☆☆☆☆';

        if (typeof getAverageRating === 'function' && typeof loadReviews === 'function') {
            avgRating = getAverageRating(product.id);
            const reviews = loadReviews()[product.id] || [];
            reviewCount = reviews.length;
            starsDisplay = renderStars(avgRating);
        }

        const ratingHtml = `
            <div class="product-rating-summary" style="display:flex; flex-direction:column; gap:0.5rem; margin-bottom:0.8rem;">
                <div style="display:flex; gap:0.5rem; width:100%;">
                    <button class="rate-btn" data-id="${product.id}" data-name="${escapeHtml(product.name)}" 
                        style="flex:1; background:var(--primary-blue); border:1px solid var(--primary-blue); color:white; padding:5px; border-radius:4px; font-size:0.85rem; cursor:pointer; transition: opacity 0.2s;">
                        ${t('product_rate')}
                    </button>
                    <button class="view-reviews-btn" data-id="${product.id}" data-name="${escapeHtml(product.name)}" 
                        style="flex:1; background:white; border:1px solid var(--primary-blue); color:var(--primary-blue); padding:5px; border-radius:4px; font-size:0.85rem; cursor:pointer; transition: background 0.2s;">
                        ${t('product_view_reviews')} (${reviewCount})
                    </button>
                </div>
            </div>
        `;

        if (product.isCustom) {
            return `
            <div class="product-card" onclick="trackProductView('${product.id}')" style="position: relative;">
                <button class="wishlist-btn ${isWishlisted ? 'active' : ''}" data-id="${product.id}" title="${t('product_wishlist_btn')}">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                    </svg>
                </button>
                <h3>${t(product.nameKey)}</h3>
                ${ratingHtml}
                <span class="price">${t('product_indiv')}</span>
                
                <div class="product-options">
                    <div class="option-group">
                        <label>${t('product_order_custom_from')}</label>
                        <input type="text" id="custom-from-${product.id}" placeholder="${t('product_custom_from_placeholder')}" class="qty-input">
                    </div>
                    <div class="option-group">
                        <label>${t('product_order_custom_to')}</label>
                        <input type="text" id="custom-to-${product.id}" placeholder="${t('product_custom_to_placeholder')}" class="qty-input">
                    </div>
                    <div class="option-group">
                        <label>${t('product_order_custom_desc')}</label>
                        <textarea id="custom-desc-${product.id}" placeholder="${t('product_custom_desc_placeholder')}" class="qty-input" style="min-height: 60px;"></textarea>
                    </div>
                    <div class="option-group">
                        <label>${t('product_order_custom_files')}</label>
                        <input type="file" id="custom-files-${product.id}" multiple class="qty-input file-input-trigger" data-id="${product.id}" style="padding: 5px;">
                        <span style="font-size: 0.75rem; color: var(--text-light);">${t('product_order_custom_files_tip')}</span>
                        <ul id="file-list-${product.id}" class="selected-files-list"></ul>
                        <div class="file-warning-box">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                            </svg>
                            <span>${t('product_order_custom_files_warning')}</span>
                        </div>
                    </div>
                </div>

                <button class="add-btn add-custom-btn" data-id="${product.id}">
                    Auftrag hinzufügen
                </button>
            </div>
            `;
        }

        if (product.images && product.images.length > 0) {
            return `
            <div class="product-card" onclick="trackProductView('${product.id}')" style="position: relative;">
                <button class="wishlist-btn ${isWishlisted ? 'active' : ''}" data-id="${product.id}" title="Auf die Wunschliste">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                    </svg>
                </button>
                <h3>${product.name}</h3>
                <div class="gallery-container">
                    <div class="gallery-slide" id="gallery-${product.id}">
                        ${product.images.map((img, i) => `
                        <div class="gallery-item" data-lightbox-src="${img}">
                            <img src="${img}" class="gallery-img">
                            <a href="gallery.html?id=${product.id}&img=${img}" target="_blank" class="maximize-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M5.828 10.172a.5.5 0 0 0-.707 0l-4.096 4.096V11.5a.5.5 0 0 0-1 0v3.975a.5.5 0 0 0 .5.5H4.5a.5.5 0 0 0 0-1H1.732l4.096-4.096a.5.5 0 0 0 0-.707zm4.344 0a.5.5 0 0 1 .707 0l4.096 4.096V11.5a.5.5 0 1 1 1 0v3.975a.5.5 0 0 1-.5.5H11.5a.5.5 0 0 1 0-1h2.768l-4.096-4.096a.5.5 0 0 1 0-.707zm0-4.344a.5.5 0 0 0 .707 0l4.096-4.096V4.5a.5.5 0 1 0 1 0V.525a.5.5 0 0 0-.5-.5H11.5a.5.5 0 0 0 0 1h2.768l-4.096 4.096a.5.5 0 0 0 0 .707zm-4.344 0a.5.5 0 0 1-.707 0L1.025 1.732V4.5a.5.5 0 0 1-1 0V.525a.5.5 0 0 1 .5-.5H4.5a.5.5 0 0 1 0 1H1.732l4.096 4.096a.5.5 0 0 1 0 .707z"/>
                                </svg>
                            </a>
                        </div>
`).join('')}
                    </div>
                </div>
                ${ratingHtml}
                ${product.description ? `<p style="color: #666; font-size: 0.9rem; margin-bottom: 0.5rem;">${product.description}</p>` : ''}
                <span class="price">${product.price.toFixed(2)} €</span>
                
                <div class="product-options">
                    <div class="option-group">
                        <label>${t('product_quantity')}</label>
                        <input type="number" id="qty-${product.id}" value="1" min="1" class="qty-input">
                    </div>
                    
                    <div class="option-group">
                        <label>${t('product_color')}</label>
                        <div class="color-preview-container">
                            <select id="color-${product.id}" class="color-select" data-id="${product.id}" onchange="updateColorPreview(this, '${product.id}')">
                                ${colors.map(c => `<option value="${c.value}">${c.name}</option>`).join('')}
                            </select>
                            <div id="preview-${product.id}" class="color-preview preview-blue"></div>
                        </div>
                    </div>

                    <div id="custom-color-wrapper-${product.id}" class="option-group" style="display: none;">
                        <label style="color: var(--primary-blue);">Ihre Wunschfarbe:</label>
                        <input type="text" id="custom-color-input-${product.id}" placeholder="Welche Farbe möchten Sie?" class="qty-input">
                        <div class="warning-msg">
                            <strong>Hinweis:</strong> Diese Farbe muss ggf. extra bestellt werden. Dadurch können zusätzliche Kosten und Wartezeiten entstehen.
                        </div>
                    </div>
                </div>

                <button class="add-btn add-to-cart-btn" data-id="${product.id}">
                    In den Warenkorb
                </button>
            </div>
            `;
        }

        return `
        <div class="product-card">
            <div class="product-gallery">
                <div class="main-image-container">
                    <div id="tint-layer-${product.id}" class="tint-layer"></div>
                    <img src="${product.images && product.images.length > 0 ? product.images[0] : 'placeholder.jpg'}" alt="${product.name}" class="product-img main-img" id="main-img-${product.id}">
                </div>
                 ${product.images && product.images.length > 1 ? `
                <div class="thumbnail-row">
                    ${product.images.map((img, index) => `
                        <img src="${img}" class="thumbnail ${index === 0 ? 'active' : ''}" 
                             onclick="switchGalleryImage('${img}', this)">
                    `).join('')}
                </div>` : ''}
            </div>

            <div class="product-info">
                <h3>${t(product.nameKey)}</h3>
                ${ratingHtml}
                ${product.descKey ? `<p style="color: var(--text-light); font-size: 0.9rem; margin-bottom: 0.5rem;">${t(product.descKey)}</p>` : ''}
                <div class="price">${product.price.toFixed(2)} €</div>
                
                <div class="product-options">
                    <div class="option-group">
                        <label>${t('product_quantity')}</label>
                        <input type="number" id="qty-${product.id}" value="1" min="1" class="qty-input">
                    </div>
                    
                    <div class="option-group">
                        <label>${t('product_color')}</label>
                        <div class="color-preview-container">
                            <select id="color-${product.id}" class="color-select" data-id="${product.id}" onchange="updateColorPreview(this, '${product.id}')">
                                ${colors.map(c => `<option value="${c.value}">${c.name}</option>`).join('')}
                            </select>
                            <div id="preview-${product.id}" class="color-preview preview-blue"></div>
                        </div>
                    </div>

                    <div id="custom-color-wrapper-${product.id}" class="option-group" style="display: none;">
                        <label style="color: var(--primary-blue);">${t('product_custom_color_label')}</label>
                        <input type="text" id="custom-color-input-${product.id}" placeholder="${t('product_custom_color_placeholder')}" class="qty-input">
                        <div class="warning-msg">
                            <strong>${t('product_custom_color_warning_ref')}</strong> ${t('product_custom_color_warning_text')}
                        </div>
                    </div>
                </div>

                <button class="add-btn add-to-cart-btn" data-id="${product.id}">
                    ${t('product_add_cart')}
                </button>
                <!-- Cart Icon Animation Container -->
                <div id="cart-animation-${product.id}" style="position: absolute; right: 20px; bottom: 80px; pointer-events: none;"></div>
            </div>
        </div>
    `}).join('');
}

// Update the little color circle when selection changes
// Update the little color circle and tint the product image
function updateColorPreview(select, id) {
    const preview = document.getElementById(`preview-${id}`);
    const customWrapper = document.getElementById(`custom-color-wrapper-${id}`);

    if (preview) preview.className = `color-preview preview-${select.value}`;

    if (select.value === 'custom') {
        if (customWrapper) customWrapper.style.display = 'block';
    } else {
        if (customWrapper) customWrapper.style.display = 'none';
    }
}

// Navigation Logic (SPA)
function setupNavigation() {
    // We use event delegation on document body to catch ALL navigation triggers
    document.body.addEventListener('click', (e) => {
        const link = e.target.closest('.nav-link, .cart-icon-container, .wishlist-icon-container, .footer-link.nav-trigger, .contact-trigger, .nav-trigger');

        if (!link) return;

        // Special check: Don't navigate if it's the dropdown toggle itself
        if (link.classList.contains('dropdown-toggle')) return;

        const targetId = link.getAttribute('data-target');

        if (targetId) {
            e.preventDefault();
            console.log('Navigating to:', targetId);
            showSection(targetId);
            window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
            // Fallback classes if data-target is missing for some reason
            if (link.classList.contains('cart-icon-container')) {
                e.preventDefault();
                showSection('cart');
            } else if (link.classList.contains('wishlist-icon-container')) {
                e.preventDefault();
                showSection('wishlist');
            }
        }
    });
}

// Bot Protection State
const SECTION_STATS = {
    contactShownAt: 0
};

function showSection(id) {
    if (id === 'contact') SECTION_STATS.contactShownAt = Date.now();
    // Hide all sections
    document.querySelectorAll('section').forEach(sec => {
        sec.classList.remove('active');
        if (sec.style.display !== 'none') sec.style.display = 'none'; // Ensure hidden
    });

    // Show target section(s)
    // Note: Home is special, it's a section.
    const target = document.getElementById(id);
    if (target) {
        target.style.setProperty('display', (id === 'home' ? 'flex' : 'block'), 'important');
        setTimeout(() => target.classList.add('active'), 10); // Small delay for fade in
    }

    // Update active nav link
    const triggers = '.nav-link, .cart-icon-container, .wishlist-icon-container, .footer-link.nav-trigger, .contact-trigger, .nav-trigger';
    document.querySelectorAll(triggers).forEach(link => {
        link.classList.remove('active');
        if (link.getAttribute('data-target') === id) {
            link.classList.add('active');
        }
    });

    if (id === 'cart') renderCart();
    if (id === 'wishlist') renderWishlist();
}

// Cart Logic for Normal Items
function addToCart(productId) {
    const product = products.find(p => p.id === productId);
    const qtyInput = document.getElementById(`qty-${productId}`);
    let qty = parseInt(qtyInput.value);

    if (isNaN(qty) || qty < 1) {
        showError(t('alert_error_qty'));
        return;
    }

    const colorSelect = document.getElementById(`color-${productId}`);
    let colorVal = colorSelect.value;
    let colorName = colors.find(c => c.value === colorVal).name;

    // Handle Custom Color
    if (colorVal === 'custom') {
        const customInput = document.getElementById(`custom-color-input-${productId}`);
        const customColorName = customInput.value.trim();

        if (customColorName.length < 2) {
            showError("Bitte geben Sie Ihre Wunschfarbe ein.");
            customInput.focus();
            return;
        }
        colorName = `Wunschfarbe: ${customColorName}`;
        // Unique ID for cart separation (otherwise 'custom' stacks)
        colorVal = `custom-${customColorName.toLowerCase().replace(/\s/g, '-')}`;
    }

    const existingItem = cart.find(item => item.id === productId && item.color === colorVal && !item.isCustom);

    if (existingItem) {
        existingItem.qty += qty;
    } else {
        cart.push({
            id: productId,
            nameKey: product.nameKey, // Use nameKey
            name: t(product.nameKey), // Support legacy code if needed
            price: product.price,
            qty: qty,
            color: colorVal,
            colorName: colorName,
            isCustom: false
        });
    }

    showSuccess(`${qty}x ${t(product.nameKey)} (${colorName}) ${t('alert_success_added')}`);
    trackProductPurchase(productId);
    saveCartToStorage();
    updateCartIcon();
};

// Cart Logic for Custom Items
function addCustomToCart(productId) {
    const product = products.find(p => p.id === productId);
    const fromVal = document.getElementById(`custom-from-${productId}`).value;
    const toVal = document.getElementById(`custom-to-${productId}`).value;
    const descVal = document.getElementById(`custom-desc-${productId}`).value;
    const fileInput = document.getElementById(`custom-files-${productId}`);
    const fileNames = fileInput && fileInput.files ? Array.from(fileInput.files).map(f => f.name) : [];

    if (!fromVal || !toVal || !descVal) {
        showError("Bitte füllen Sie alle Felder für den Auftrag aus.");
        return;
    }

    cart.push({
        id: productId,
        name: product.name,
        price: 0,
        qty: 1,
        isCustom: true,
        customFrom: fromVal,
        customTo: toVal,
        customDesc: descVal,
        files: fileNames
    });

    showSuccess(t('alert_success_added'));
    if (fileNames.length > 0) {
        showWarning(`WICHTIG: Bitte hängen Sie die ${fileNames.length} Datei(en) später an Ihre E-Mail an.`, 6000);
    }

    // Clear inputs
    document.getElementById(`custom-from-${productId}`).value = '';
    document.getElementById(`custom-to-${productId}`).value = '';
    document.getElementById(`custom-desc-${productId}`).value = '';

    saveCartToStorage();
    updateCartIcon();
}

function removeFromCart(index) {
    cart.splice(index, 1);
    saveCartToStorage();
    renderCart(); // Re-render cart to show updates
    updateCartIcon();
};

function updateCartIcon() {
    const totalQty = cart.reduce((sum, item) => sum + item.qty, 0);
    document.getElementById('cart-count').innerText = totalQty;
}

function renderCart() {
    const container = document.getElementById('cart-items-container');
    const summaryContainer = document.getElementById('cart-summary');

    if (cart.length === 0) {
        container.innerHTML = `<p>${t('cart_empty')}</p>`;
        summaryContainer.style.display = 'none';
        return;
    }

    summaryContainer.style.display = 'block';

    container.innerHTML = cart.map((item, index) => {
        const displayName = item.nameKey ? t(item.nameKey) : item.name;
        if (item.isCustom) {
            const escapedDesc = escapeHtml(item.customDesc);
            const escapedFrom = escapeHtml(item.customFrom);
            const escapedTo = escapeHtml(item.customTo);
            return `
            <div class="cart-item">
                <div class="cart-item-details">
                    <h4>${displayName}</h4>
                    <div class="cart-item-info">
                        <strong>${t('cart_item_order')}</strong> ${escapedDesc}<br>
                        <strong>${t('cart_item_from')}</strong> ${escapedFrom} | <strong>${t('cart_item_to')}</strong> ${escapedTo}
                        ${item.files && item.files.length > 0 ? `
                            <div style="margin-top:5px; font-size:0.8rem;">
                                <strong>${t('cart_item_files')}</strong>
                                <ul style="margin: 0; padding-left: 1.2rem; list-style-type: disc;">
                                    ${item.files.map(f => `<li><code>${escapeHtml(f)}</code></li>`).join('')}
                                </ul>
                            </div>
                        ` : ''}
                    </div>
                </div>
                <div style="display:flex; align-items:center; gap: 1rem;">
                    <strong>${t('cart_item_price_on_request')}</strong>
                    <button class="remove-btn" data-index="${index}" title="${t('cart_item_remove')}">
                        ${t('cart_item_remove')}
                    </button>
                </div>
            </div>`;
        } else {
            const escapedColor = escapeHtml(item.colorName);
            return `
            <div class="cart-item">
                <div class="cart-item-details">
                    <h4>${displayName}</h4>
                    <div class="cart-item-info">${t('cart_item_qty')} ${item.qty} | ${t('cart_item_color')} ${escapedColor} | ${t('cart_item_unit_price')} ${item.price.toFixed(2)}€</div>
                </div>
                <div style="display:flex; align-items:center; gap: 1rem;">
                    <strong>${(item.price * item.qty).toFixed(2)} €</strong>
                    <button class="remove-btn" data-index="${index}" title="${t('cart_item_remove')}">
                        ${t('cart_item_remove')}
                    </button>
                </div>
            </div>`;
        }
    }).join('');

    // Update icons in HTML string (hacky reuse of SVG separately to keep code clean above)
    // Fixed the SVG issue by just using text "Remove" or simplified SVG above. 
    // Let's perform a quick replacement to ensure the trash icon is there if nice.
    // Actually, I just used text "Remove" to avoid big SVG block in map. 
    // Let's stick the SVG back in for polish.
    const trashSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>`;
    container.querySelectorAll('.remove-btn').forEach(btn => btn.innerHTML = trashSvg);

    // Add highlighted warning if custom files are present
    const customItemsWithFiles = cart.filter(item => item.isCustom && item.files && item.files.length > 0);
    const existingWarning = document.getElementById('cart-file-warning');
    if (existingWarning) existingWarning.remove();

    if (customItemsWithFiles.length > 0) {
        const warningDiv = document.createElement('div');
        warningDiv.id = 'cart-file-warning';
        warningDiv.className = 'file-warning-box';
        warningDiv.style.margin = '1rem 0';
        warningDiv.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
            </svg>
            <span>${t('cart_file_warning_text')}</span>
        `;
        container.prepend(warningDiv);
    }


    const hasCustom = cart.some(item => item.isCustom);
    const hasRegular = cart.some(item => !item.isCustom);
    const subtotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
    const discount = calculateDiscount(subtotal);
    const total = subtotal - discount + SHIPPING_COST;

    if (!hasRegular && hasCustom) {
        // Only custom items
        document.getElementById('subtotal').innerText = t('cart_price_indiv');
        document.getElementById('shipping').innerText = t('cart_shipping_cost_indiv');
        document.getElementById('total-sum').innerText = t('cart_price_indiv');
    } else if (hasRegular && hasCustom) {
        // Mixed items
        document.getElementById('subtotal').innerText = subtotal.toFixed(2) + ` € (${t('cart_extra_charge_info')})`;
        if (discount > 0) {
            document.getElementById('discount-row').style.display = 'flex';
            document.getElementById('discount').innerText = '-' + discount.toFixed(2) + ' €';
        } else {
            document.getElementById('discount-row').style.display = 'none';
        }
        document.getElementById('shipping').innerText = SHIPPING_COST.toFixed(2) + ` € (${t('cart_shipping_extra_info')})`;
        document.getElementById('total-sum').innerText = total.toFixed(2) + ` € (${t('cart_extra_charge_info')})`;
    } else {
        // Only regular items
        document.getElementById('subtotal').innerText = subtotal.toFixed(2) + ' €';
        if (discount > 0) {
            document.getElementById('discount-row').style.display = 'flex';
            document.getElementById('discount').innerText = '-' + discount.toFixed(2) + ' €';
        } else {
            document.getElementById('discount-row').style.display = 'none';
        }
        document.getElementById('shipping').innerText = SHIPPING_COST.toFixed(2) + ' €';
        document.getElementById('total-sum').innerText = total.toFixed(2) + ' €';
    }

    // Update coupon UI
    const couponSection = document.getElementById('coupon-section');
    if (couponSection) {
        if (appliedCoupon) {
            couponSection.innerHTML = `
                <div class="coupon-applied">
                    <span>✓ Gutschein "${appliedCoupon.code}" angewendet</span>
                    <button class="coupon-remove-btn" onclick="removeCoupon()">✕</button>
                </div>
            `;
        } else {
            couponSection.innerHTML = `
                <div class="coupon-input-group">
                    <input type="text" id="coupon-input" class="coupon-input" placeholder="${t('cart_coupon_label')}">
                    <button id="apply-coupon-btn" class="coupon-apply-btn">${t('cart_coupon_btn')}</button>
                </div>
            `;
            // Re-attach event listener
            setTimeout(() => {
                const btn = document.getElementById('apply-coupon-btn');
                if (btn) btn.addEventListener('click', applyCoupon);
            }, 0);
        }
    }
}




// Modern Checkout System
let checkoutData = {};
let currentCheckoutStep = 1;

function checkout() {
    if (cart.length === 0) {
        showWarning(t('cart_empty'));
        return;
    }

    checkoutData = {};
    currentCheckoutStep = 1;

    // Clear previous errors
    document.querySelectorAll('.form-error').forEach(el => el.textContent = '');
    document.querySelectorAll('.form-input').forEach(el => el.classList.remove('error', 'success'));

    // Reset inputs
    document.getElementById('checkout-name').value = '';
    document.getElementById('checkout-email').value = '';
    document.getElementById('checkout-address').value = '';
    document.getElementById('checkout-zip').value = '';
    document.getElementById('checkout-city').value = '';

    const modal = document.getElementById('checkout-modal');
    modal.classList.add('show');
    showCheckoutStep(1);
}

function closeCheckoutModal() {
    const modal = document.getElementById('checkout-modal');
    modal.classList.remove('show');
}

function showCheckoutStep(step) {
    console.log('showing checkout step:', step);
    currentCheckoutStep = step;

    // Hide all steps and remove active class
    document.querySelectorAll('.checkout-step').forEach(el => {
        el.style.display = 'none';
        el.classList.remove('active');
    });

    // Show current step
    const targetStep = document.getElementById(`checkout-step-${step}`);
    if (targetStep) {
        targetStep.style.display = 'block';
        targetStep.classList.add('active');

        // Ensure the modal scrolls to top
        const modalContent = targetStep.closest('.modal-content');
        if (modalContent) modalContent.scrollTop = 0;
    } else {
        console.error('Checkout step element not found:', step);
        showError('Ein technischer Fehler ist aufgetreten. Bitte laden Sie die Seite neu.');
    }

    // Update progress bar
    document.querySelectorAll('.progress-step').forEach(el => {
        const stepNum = parseInt(el.getAttribute('data-step'));
        el.classList.remove('active', 'completed');
        if (stepNum === step) {
            el.classList.add('active');
        } else if (stepNum < step) {
            el.classList.add('completed');
        }
    });

    if (step === 3) {
        renderCheckoutSummary();
    }
}

function nextCheckoutStep() {
    try {
        console.log('nextCheckoutStep called. Current step:', currentCheckoutStep);
        if (validateCheckoutStep(currentCheckoutStep)) {
            console.log('Validation passed. Moving to step:', currentCheckoutStep + 1);
            showCheckoutStep(currentCheckoutStep + 1);
        } else {
            console.log('Validation failed for step:', currentCheckoutStep);
        }
    } catch (e) {
        console.error('nextCheckoutStep error:', e);
        showError('Fehler: ' + e.message);
    }
}

function prevCheckoutStep() {
    if (currentCheckoutStep > 1) {
        showCheckoutStep(currentCheckoutStep - 1);
    }
}

function validateCheckoutStep(step) {
    console.log('Validating step:', step);
    let isValid = true;

    if (step === 1) {
        const nameInput = document.getElementById('checkout-name');
        const emailInput = document.getElementById('checkout-email');

        if (nameInput.value.trim().length < 2) {
            setError(nameInput, 'Bitte geben Sie Ihren Namen ein (min. 2 Zeichen).');
            isValid = false;
        } else {
            setSuccess(nameInput);
        }

        if (!emailInput.value.includes('@') || emailInput.value.length < 5) {
            setError(emailInput, 'Bitte eine gültige E-Mail-Adresse eingeben.');
            isValid = false;
        } else {
            setSuccess(emailInput);
        }
    } else if (step === 2) {
        const addressInput = document.getElementById('checkout-address');
        const zipInput = document.getElementById('checkout-zip');
        const cityInput = document.getElementById('checkout-city');

        if (addressInput.value.trim().length < 5) {
            setError(addressInput, 'Bitte Ihre Adresse eingeben (min. 5 Zeichen).');
            isValid = false;
        } else {
            setSuccess(addressInput);
        }

        if (!/^[0-9]{4,5}$/.test(zipInput.value.trim())) {
            setError(zipInput, 'Gültige PLZ eingeben.');
            isValid = false;
        } else {
            setSuccess(zipInput);
        }

        if (cityInput.value.trim().length < 2) {
            setError(cityInput, 'Bitte Ihren Ort eingeben.');
            isValid = false;
        } else {
            setSuccess(cityInput);
        }
    }

    if (!isValid) {
        showWarning('Bitte füllen Sie alle markierten Felder korrekt aus.');
    }
    return isValid;
}

function setError(input, message) {
    if (!input) return;
    input.classList.add('error');
    input.classList.remove('success');
    const errorSpan = input.parentElement.querySelector('.form-error');
    if (errorSpan) errorSpan.textContent = message;
}

function setSuccess(input) {
    if (!input) return;
    input.classList.remove('error');
    input.classList.add('success');
    const errorSpan = input.parentElement.querySelector('.form-error');
    if (errorSpan) errorSpan.textContent = '';
}

function renderCheckoutSummary() {
    const summary = document.getElementById('checkout-summary');
    const name = document.getElementById('checkout-name').value;
    const email = document.getElementById('checkout-email').value;
    const address = document.getElementById('checkout-address').value;
    const zip = document.getElementById('checkout-zip').value;
    const city = document.getElementById('checkout-city').value;

    let itemsHtml = cart.map(item => {
        if (item.isCustom) {
            return `<li>[${typeof t === 'function' ? t('nav_more') : 'AUFTRAG'}] ${item.name} (${item.customDesc})</li>`;
        } else {
            return `<li>${item.qty}x ${item.name} (${item.colorName}) - ${(item.price * item.qty).toFixed(2)}€</li>`;
        }
    }).join('');

    const subtotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
    const discount = calculateDiscount(subtotal);
    const total = subtotal - discount + SHIPPING_COST;

    const shippingAddrHeader = typeof t === 'function' ? t('summary_shipping_address') : 'Lieferadresse:';
    const orderPreviewHeader = typeof t === 'function' ? t('summary_order_preview') : 'Bestellübersicht:';
    const shippingLabel = typeof t === 'function' ? t('cart_shipping') : 'Versand:';
    const totalLabel = typeof t === 'function' ? t('cart_total') : 'Gesamt:';
    const discountLabel = typeof t === 'function' ? t('cart_discount') : 'Rabatt:';

    summary.innerHTML = `
        <div style="margin-bottom: 1rem; border-bottom: 1px solid #ddd; padding-bottom: 0.5rem;">
            <strong>${shippingAddrHeader}</strong><br>
            ${name}<br>
            ${address}<br>
            ${zip} ${city}<br>
            E-Mail: ${email}
        </div>
        <div>
            <strong>${orderPreviewHeader}</strong>
            <ul style="padding-left: 1.2rem; margin: 0.5rem 0;">${itemsHtml}</ul>
            <div style="border-top: 1px solid #ddd; margin-top: 0.5rem; padding-top: 0.5rem;">
                ${discount > 0 ? `${discountLabel} -${discount.toFixed(2)}€<br>` : ''}
                ${shippingLabel} ${SHIPPING_COST.toFixed(2)}€<br>
                <strong>${totalLabel} ${total.toFixed(2)}€</strong>
            </div>
        </div>
    `;
}

function submitCheckout() {
    console.log('submitCheckout called');
    const nameInput = document.getElementById('checkout-name');
    const emailInput = document.getElementById('checkout-email');
    const addressInput = document.getElementById('checkout-address');
    const zipInput = document.getElementById('checkout-zip');
    const cityInput = document.getElementById('checkout-city');

    if (!nameInput || !emailInput || !addressInput || !zipInput || !cityInput) {
        console.error('One or more checkout input elements missing');
        return;
    }

    const name = nameInput.value;
    const email = emailInput.value;
    const address = addressInput.value;
    const zip = document.getElementById('checkout-zip').value;
    const city = document.getElementById('checkout-city').value;

    const fullAddress = `${address}, ${zip} ${city}`;
    const orderId = generateOrderId();

    let body = `Hallo Druckbau Team,\n\nIch möchte folgende Bestellung aufgeben:\nBestellnummer: ${orderId}\n\nKundendaten:\nName: ${name}\nAdresse: ${address}\nOrt: ${zip} ${city}\nE-Mail: ${email}\n\nBestellung:\n`;

    cart.forEach(item => {
        if (item.isCustom) {
            body += `- [AUFTRAGSARBEIT] ${item.name}\n  Von: ${item.customFrom}\n  Zu: ${item.customTo}\n  Info: ${item.customDesc}\n`;
            if (item.files && item.files.length > 0) {
                body += `  !! BITTE ANHÄNGEN !! Dateien: ${item.files.join(', ')}\n`;
            }
        } else {
            body += `- ${item.qty}x ${item.name} (${item.colorName}) - ${(item.price * item.qty).toFixed(2)}€\n`;
        }
    });

    const subtotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
    const discount = calculateDiscount(subtotal);
    const total = subtotal - discount + SHIPPING_COST;

    body += `\nZwischensumme: ${subtotal.toFixed(2)}€\n`;
    if (discount > 0) body += `Rabatt: -${discount.toFixed(2)}€\n`;
    body += `Versand: ${SHIPPING_COST.toFixed(2)}€\n`;
    body += `Gesamt: ${total.toFixed(2)}€\n`;

    if (appliedCoupon) {
        body += `\nGutschein: ${appliedCoupon.code}\n`;
    }

    body += `\nVielen Dank!`;

    logOrder(name, email, orderId, body, appliedCoupon ? { code: appliedCoupon.code, discount: discount } : null);

    const mailtoLink = `mailto:druckbau.info@gmail.com?subject=Bestellung ${orderId}&body=${encodeURIComponent(body)}`;

    const tempLink = document.createElement('a');
    tempLink.href = mailtoLink;
    tempLink.style.display = 'none';
    document.body.appendChild(tempLink);
    tempLink.click();
    document.body.removeChild(tempLink);

    cart = [];
    saveCartToStorage();
    updateCartIcon();
    renderCart();
    closeCheckoutModal();

    showSuccess(t('checkout_prepare_success'));
}

