// Explicitly define global functions for the onclick handlers in HTML
function openLightbox(src) {
    const lightbox = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img');
    if (lightbox && img) {
        img.src = src;
        lightbox.style.display = 'flex';
    }
}

function closeLightbox() {
    const lightbox = document.getElementById('lightbox');
    if (lightbox) {
        lightbox.style.display = 'none';
    }
}

// --- Product Review System ---

function loadReviews() {
    try {
        return safeJSONParse('productReviews', {});
    } catch (e) {
        return {};
    }
}

function saveReview(productId, review) {
    const reviews = loadReviews();
    if (!reviews[productId]) {
        reviews[productId] = [];
    }
    reviews[productId].push(review);
    localStorage.setItem('productReviews', JSON.stringify(reviews));
}

function getAverageRating(productId) {
    const reviews = loadReviews();
    const productReviews = reviews[productId] || [];
    if (productReviews.length === 0) return 0;

    const sum = productReviews.reduce((acc, r) => acc + parseInt(r.rating), 0);
    return (sum / productReviews.length).toFixed(1);
}

function renderStars(rating) {
    const fullStars = Math.floor(rating);
    const halfStar = rating % 1 >= 0.5;
    let starsHtml = '';

    for (let i = 0; i < 5; i++) {
        if (i < fullStars) {
            starsHtml += '★';
        } else if (i === fullStars && halfStar) {
            starsHtml += '½';
        } else {
            starsHtml += '☆';
        }
    }
    return starsHtml;
    return starsHtml;
}



function renderReviewList(productId) {
    const listContainer = document.getElementById('reviews-list-container');
    if (!listContainer) return;

    const reviews = loadReviews()[productId] || [];
    const currentUser = localStorage.getItem('reviewUsername');

    if (reviews.length === 0) {
        listContainer.innerHTML = '<p style="color: var(--text-light); font-style: italic;">Noch keine Bewertungen.</p>';
        return;
    }

    listContainer.innerHTML = reviews.map((review, index) => {
        // Star display helper
        let stars = '';
        for (let i = 0; i < 5; i++) stars += i < review.rating ? '★' : '☆';

        // Check ownership
        const isOwner = currentUser && review.author === currentUser;

        let imageHtml = '';
        if (review.image) {
            imageHtml = `<img src="${review.image}" alt="Review Bild" style="max-width: 100px; max-height: 100px; border-radius: 4px; margin-top: 0.5rem; display: block; object-fit: cover;">`;
        }

        return `
        <div class="review-item" style="position: relative;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.3rem;">
                <strong style="font-size: 0.95rem;">${escapeHtml(review.author)}</strong>
                <span style="color: #fbbf24;">${stars}</span>
            </div>
            <p style="font-size: 0.9rem; margin-bottom: 0.3rem; line-height: 1.4;">${escapeHtml(review.text)}</p>
            ${imageHtml}
            <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; color: var(--text-light); margin-top: 0.5rem;">
                <span>${review.date}</span>
                <button class="delete-review-btn" data-product-id="${productId}" data-index="${index}" data-is-owner="${isOwner}"
                    style="border: none; background: none; color: ${isOwner ? '#d9534f' : '#999'}; cursor: pointer; text-decoration: underline;">
                    ${isOwner ? 'Löschen' : 'Admin: Löschen'}
                </button>
            </div>
        </div>
        `;
    }).join('');
}

function deleteReviewInternal(productId, reviewIndex, isOwner) {
    const reviews = loadReviews();
    if (!reviews[productId]) return;

    if (isOwner) {
        if (!confirm('Möchtest du deine Bewertung wirklich löschen?')) return;
    } else {
        // Not owner -> Admin check
        const password = prompt("Admin Passwort eingeben (Standard: admin123):");
        if (password !== 'admin123') {
            alert("Falsches Passwort!");
            return;
        }
    }

    // Perform deletion
    reviews[productId].splice(reviewIndex, 1);
    localStorage.setItem('productReviews', JSON.stringify(reviews));

    // Refresh UI
    renderReviewList(productId);
    renderProducts(); // Update stars/counts on main page
}


window.openViewReviewsModal = function (productId, productName) {
    document.getElementById('review-product-name').textContent = `Bewertungen: ${productName}`;

    // Hide form, Show list
    const form = document.getElementById('review-form');
    if (form) form.style.display = 'none';

    const listSection = document.querySelector('.existing-reviews-section');
    if (listSection) {
        listSection.style.display = 'block';
        listSection.style.borderTop = 'none'; // Clean look
        listSection.style.marginTop = '0';
    }

    const modal = document.getElementById('review-modal');
    if (modal) {
        modal.classList.add('show');
        modal.style.display = 'flex';
    }

    renderReviewList(productId);
}

// Updated openRateModal to show form AND list
window.openRateModal = function (productId, productName) {
    document.getElementById('review-product-id').value = productId;
    document.getElementById('review-product-name').textContent = `Bewerten: ${productName}`;

    // Show form
    const form = document.getElementById('review-form');
    if (form) form.style.display = 'block';

    // Show list (User request: "show all reviews also")
    // Show list (User request: "show all reviews also" -> correction: NO, only in "View Reviews")
    const listSection = document.querySelector('.existing-reviews-section');
    if (listSection) {
        listSection.style.display = 'none';
    }

    // Form prep logic
    const savedName = localStorage.getItem('reviewUsername');
    const nameGroup = document.getElementById('review-name-group');
    const nameInput = document.getElementById('review-author');

    if (savedName) {
        nameInput.value = savedName;
        if (nameGroup) nameGroup.style.display = 'none';
    } else {
        nameInput.value = '';
        if (nameGroup) nameGroup.style.display = 'block';
    }

    document.getElementById('review-text').value = '';
    const radios = document.getElementsByName('rating');
    radios.forEach(r => r.checked = false);

    const modal = document.getElementById('review-modal');
    if (modal) {
        modal.classList.add('show');
        modal.style.display = 'flex';
    }

    // Render list so user sees previous reviews while rating
    renderReviewList(productId);
}


// Event Listeners for Review System (run once on load)
document.addEventListener('DOMContentLoaded', () => {
    const reviewModal = document.getElementById('review-modal');
    const reviewForm = document.getElementById('review-form');

    if (reviewModal) {
        const closeBtn = reviewModal.querySelector('.close-modal');
        if (closeBtn) {
            closeBtn.addEventListener('click', () => {
                reviewModal.classList.remove('show');
                reviewModal.style.display = 'none';
            });
        }

        // Close on outside click
        reviewModal.addEventListener('click', (e) => {
            if (e.target === reviewModal) {
                reviewModal.classList.remove('show');
                reviewModal.style.display = 'none';
            }
        });
    }

    if (reviewForm) {
        reviewForm.addEventListener('submit', (e) => {
            e.preventDefault();

            const productId = document.getElementById('review-product-id').value;
            const author = document.getElementById('review-author').value;
            const text = document.getElementById('review-text').value;
            const imageInput = document.getElementById('review-image');
            const ratingInputs = document.getElementsByName('rating');
            let rating = 0;

            for (const input of ratingInputs) {
                if (input.checked) {
                    rating = input.value;
                    break;
                }
            }

            if (rating === 0) {
                alert('Bitte wählen Sie eine Stern-Bewertung aus.');
                return;
            }

            // Image handling
            let imageData = null;
            if (imageInput.files && imageInput.files[0]) {
                const file = imageInput.files[0];
                if (file.size > 500 * 1024) { // 500KB limit
                    alert('Das Bild ist zu groß (Max. 500KB).');
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (e) {
                    imageData = e.target.result;
                    saveAndClose(imageData);
                };
                reader.readAsDataURL(file);
            } else {
                saveAndClose(null);
            }

            function saveAndClose(img) {
                // Save username if provided
                if (author) {
                    localStorage.setItem('reviewUsername', author);
                }

                const review = {
                    author: author || "Anonym",
                    text: text,
                    rating: rating,
                    date: new Date().toLocaleDateString(),
                    image: img
                };

                saveReview(productId, review);

                if (reviewModal) {
                    reviewModal.classList.remove('show');
                    reviewModal.style.display = 'none';
                }

                alert('Vielen Dank für deine Bewertung!');

                // Clear input
                imageInput.value = '';

                renderProducts();
            }
        });
    }

    // Initialize News/Admin
    if (window.initNewsSystem) window.initNewsSystem();
    if (window.initAdminSystem) window.initAdminSystem();
});

// --- News System ---
function initNewsSystem() {
    const banner = document.getElementById('public-news-banner');
    if (!banner) return;

    const newsList = JSON.parse(localStorage.getItem('druckbau_news_list')) || [];

    if (newsList.length > 0) {
        const latest = newsList[0]; // The list is unshifted, so 0 is newest
        document.getElementById('news-text').innerHTML = escapeHtml(latest.text).replace(/\n/g, '<br>');
        document.getElementById('news-date').textContent = `Aktualisiert: ${latest.date}`;
    } else {
        document.getElementById('news-text').textContent = "Aktuell gibt es keine besonderen Neuigkeiten. Wir drucken fleißig! 🖨️";
        document.getElementById('news-date').textContent = "";
    }
}

// --- Analytics System ---
function trackProductView(productId) {
    const stats = safeJSONParse('druckbau_stats', { views: {}, purchases: {}, youtube_clicks: 0 });
    stats.views[productId] = (stats.views[productId] || 0) + 1;
    localStorage.setItem('druckbau_stats', JSON.stringify(stats));
}

function trackProductPurchase(productId) {
    const stats = safeJSONParse('druckbau_stats', { views: {}, purchases: {}, youtube_clicks: 0 });
    stats.purchases[productId] = (stats.purchases[productId] || 0) + 1;
    localStorage.setItem('druckbau_stats', JSON.stringify(stats));
}

function trackYouTubeClick() {
    const stats = safeJSONParse('druckbau_stats', { views: {}, purchases: {}, youtube_clicks: 0 });
    stats.youtube_clicks = (stats.youtube_clicks || 0) + 1;
    localStorage.setItem('druckbau_stats', JSON.stringify(stats));
}

// --- Admin System ---
// Security State
const ADMIN_SECURITY = {
    attempts: 0,
    maxAttempts: 3,
    lockoutUntil: 0
};

function initAdminSystem() {
    const trigger = document.getElementById('admin-trigger');
    const panel = document.getElementById('admin-panel');
    const saveNewsBtn = document.getElementById('save-news-btn');
    const deleteNewsBtn = document.getElementById('delete-news-btn');
    const clearOrdersBtn = document.getElementById('clear-orders-btn');

    if (trigger) {
        let clickCount = 0;
        let lastClickTime = 0;

        trigger.addEventListener('click', () => {
            const currentTime = new Date().getTime();
            if (currentTime - lastClickTime < 500) {
                clickCount++;
            } else {
                clickCount = 1;
            }
            lastClickTime = currentTime;

            if (clickCount === 3) {
                clickCount = 0;

                const now = Date.now();
                if (now < ADMIN_SECURITY.lockoutUntil) {
                    const remaining = Math.ceil((ADMIN_SECURITY.lockoutUntil - now) / 1000);
                    alert(`Zu viele Fehlversuche. Bitte warten Sie ${remaining} Sekunden.`);
                    return;
                }

                const pwd = prompt("Admin Passwort:");
                if (pwd === 'admin123') {
                    ADMIN_SECURITY.attempts = 0;
                    // Reveal Nav Item
                    const adminNavItem = document.getElementById('admin-nav-item');
                    if (adminNavItem) adminNavItem.style.display = 'list-item';

                    // Switch to section
                    if (typeof showSection === 'function') {
                        showSection('admin');
                    }

                    loadAdminData();
                } else if (pwd !== null) {
                    ADMIN_SECURITY.attempts++;
                    if (ADMIN_SECURITY.attempts >= ADMIN_SECURITY.maxAttempts) {
                        ADMIN_SECURITY.lockoutUntil = Date.now() + 60000; // 1 min lockout
                        alert("Maximale Versuche erreicht. Zugriff für 1 Minute gesperrt.");
                    } else {
                        alert(`Zugriff verweigert. (${ADMIN_SECURITY.attempts}/${ADMIN_SECURITY.maxAttempts})`);
                    }
                }
            }
        });
    }

    if (saveNewsBtn) {
        saveNewsBtn.addEventListener('click', () => {
            const text = document.getElementById('admin-news-input').value;
            if (text) {
                const date = new Date().toLocaleString();
                const newsList = safeJSONParse('druckbau_news_list', []);
                newsList.unshift({ text, date }); // Add to top
                localStorage.setItem('druckbau_news_list', JSON.stringify(newsList));

                alert("Status hinzugefügt!");
                document.getElementById('admin-news-input').value = '';
                initNewsSystem(); // Refresh public view
                loadAdminData(); // Refresh history list
            }
        });
    }

    if (deleteNewsBtn) {
        deleteNewsBtn.addEventListener('click', () => {
            if (confirm("Möchtest du den gesamten Neuigkeiten-Verlauf löschen?")) {
                localStorage.removeItem('druckbau_news_list');
                initNewsSystem();
                loadAdminData();
                alert("Verlauf gelöscht.");
            }
        });
    }

    if (clearOrdersBtn) {
        clearOrdersBtn.addEventListener('click', () => {
            if (confirm("Wirklich alle Bestellungen aus der Liste löschen?")) {
                localStorage.removeItem('druckbau_orders');
                loadAdminData();
            }
        });
    }

    // Event delegation for deleting individual news items & status updates
    const historyContainer = document.getElementById('admin-news-history');
    if (historyContainer) {
        historyContainer.addEventListener('click', (e) => {
            if (e.target.classList.contains('delete-news-item')) {
                const index = parseInt(e.target.getAttribute('data-index'));
                const newsList = JSON.parse(localStorage.getItem('druckbau_news_list')) || [];
                newsList.splice(index, 1);
                localStorage.setItem('druckbau_news_list', JSON.stringify(newsList));
                initNewsSystem();
                loadAdminData();
            }
        });
    }

    const ordersTable = document.getElementById('orders-table');
    if (ordersTable) {
        ordersTable.addEventListener('change', (e) => {
            if (e.target.classList.contains('order-status-select')) {
                const index = parseInt(e.target.getAttribute('data-index'));
                const newStatus = e.target.value;
                const orders = safeJSONParse('druckbau_orders', []);
                if (orders[index]) {
                    orders[index].status = newStatus;
                }
            }
        });
    }

    const deleteCompletedBtn = document.getElementById('delete-completed-orders-btn');
    if (deleteCompletedBtn) {
        deleteCompletedBtn.addEventListener('click', () => {
            if (confirm("Wirklich alle erledigten (versendeten) Bestellungen löschen?")) {
                let orders = JSON.parse(localStorage.getItem('druckbau_orders')) || [];
                const initialLength = orders.length;
                orders = orders.filter(o => o.status !== 'Versendet');
                localStorage.setItem('druckbau_orders', JSON.stringify(orders));
                loadAdminData();
                alert(`${initialLength - orders.length} erledigte Bestellungen gelöscht.`);
            }
        });
    }

    // Admin: Add Coupon
    const addCouponBtn = document.getElementById('add-coupon-btn');
    if (addCouponBtn) {
        addCouponBtn.addEventListener('click', addAdminCoupon);
    }

    // Admin: Event Delegation for Coupon Deletion (Fixes CSP issue)
    const couponTable = document.getElementById('admin-coupons-table');
    if (couponTable) {
        couponTable.addEventListener('click', (e) => {
            const btn = e.target.closest('button');
            if (btn && btn.textContent === 'Löschen') {
                const code = btn.getAttribute('data-code');
                if (code) deleteCoupon(code);
            }
        });
    }

    // Admin: Chart Range Listener
    const chartRange = document.getElementById('admin-chart-range');
    if (chartRange) {
        chartRange.addEventListener('change', renderOrdersChart);
    }
}

function initNewsletterSystem() {
    const form = document.getElementById('newsletter-form');
    if (!form) return;

    form.addEventListener('submit', (e) => {
        e.preventDefault();
        const emailInput = document.getElementById('newsletter-email');
        const email = emailInput.value;
        const gdpr = document.getElementById('newsletter-gdpr').checked;

        if (!email || !gdpr) return;

        const subscribers = safeJSONParse('druckbau_subscribers', []);

        // Check if already exists
        if (subscribers.some(s => s.email === email)) {
            alert("Diese E-Mail ist bereits angemeldet.");
            return;
        }

        subscribers.unshift({
            email,
            date: new Date().toLocaleDateString()
        });
        localStorage.setItem('druckbau_subscribers', JSON.stringify(subscribers));

        triggerAdminRefresh();
        alert("Vielen Dank! Sie sind nun für den Newsletter angemeldet.");
        form.reset();
    });

    const unsubscribeBtn = document.getElementById('newsletter-unsubscribe-btn');
    if (unsubscribeBtn) {
        unsubscribeBtn.addEventListener('click', () => {
            const email = document.getElementById('newsletter-email').value;
            if (!email) {
                alert("Bitte geben Sie Ihre E-Mail-Adresse zum Abmelden ein.");
                return;
            }

            if (confirm("Möchten Sie sich wirklich vom Newsletter abmelden?")) {
                let subscribers = JSON.parse(localStorage.getItem('druckbau_subscribers')) || [];
                const initialLength = subscribers.length;
                subscribers = subscribers.filter(s => s.email !== email);

                if (subscribers.length < initialLength) {
                    localStorage.setItem('druckbau_subscribers', JSON.stringify(subscribers));
                    alert("Sie wurden erfolgreich vom Newsletter abgemeldet.");
                    document.getElementById('newsletter-email').value = '';
                } else {
                    alert("Diese E-Mail-Adresse wurde nicht in unserer Liste gefunden.");
                }
            }
        });
    }
}

function loadAdminData() {
    // 1. Render News History
    const newsList = JSON.parse(localStorage.getItem('druckbau_news_list')) || [];
    const historyContainer = document.getElementById('admin-news-history');
    if (historyContainer) {
        if (newsList.length === 0) {
            historyContainer.innerHTML = '<p style="font-size:0.9rem; color:#999; text-align:center;">Kein Verlauf vorhanden.</p>';
        } else {
            historyContainer.innerHTML = newsList.map((item, index) => `
                <div style="border-bottom:1px solid #eee; padding:0.5rem 0; display:flex; justify-content:space-between; align-items:flex-start;">
                    <div style="font-size:0.85rem;">
                        <div style="font-weight:bold; color:var(--primary-blue);">${item.date}</div>
                        <div>${escapeHtml(item.text).replace(/\n/g, '<br>')}</div>
                    </div>
                    <button class="delete-news-item" data-index="${index}" style="background:none; border:none; color:#d9534f; cursor:pointer; font-size:1.2rem;" title="Löschen">&times;</button>
                </div>
            `).join('');
        }
    }

    // 2. Render Orders Table
    const orders = safeJSONParse('druckbau_orders', []);
    const ordersBody = document.querySelector('#orders-table tbody');
    if (ordersBody) {
        if (orders.length === 0) {
            ordersBody.innerHTML = '<tr><td colspan="6" style="padding:1rem; text-align:center;">Keine Bestellungen vorhanden.</td></tr>';
        } else {
            ordersBody.innerHTML = orders.map((order, index) => {
                const status = order.status || 'Eingegangen';
                const options = ['Eingegangen', 'In Bearbeitung', 'Gedruckt', 'Versendet'].map(opt =>
                    `<option value="${opt}" ${status === opt ? 'selected' : ''}>${opt}</option>`
                ).join('');

                return `
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 0.5rem; font-size: 0.9rem;">${order.date}</td>
                        <td style="padding: 0.5rem;">${escapeHtml(order.name)}</td>
                        <td style="padding: 0.5rem; font-family:monospace;">${escapeHtml(order.orderId)}</td>
                        <td style="padding: 0.5rem;">${escapeHtml(order.email)}</td>
                        <td style="padding: 0.5rem; font-size: 0.9rem;">${escapeHtml(order.message)}</td>
                        <td style="padding: 0.5rem; font-size: 0.85rem; color: var(--primary-blue);">
                            ${order.coupon ? `${order.coupon.code}<br><small>(-${formatCurrency(order.coupon.discount)})</small>` : '-'}
                        </td>
                        <td style="padding: 0.5rem;">
                            <select class="order-status-select" data-index="${index}" style="padding:2px; font-size:0.8rem; border-radius:4px; border:1px solid #ccc;">
                                ${options}
                            </select>
                        </td>
                    </tr>
                `;
            }).join('');
        }
    }

    // 3. Render Newsletter Table
    const subscribers = JSON.parse(localStorage.getItem('druckbau_subscribers')) || [];
    const newsletterBody = document.querySelector('#newsletter-table tbody');
    if (newsletterBody) {
        if (subscribers.length === 0) {
            newsletterBody.innerHTML = '<tr><td colspan="3" style="padding:1rem; text-align:center;">Keine Abonnenten.</td></tr>';
        } else {
            newsletterBody.innerHTML = subscribers.map((sub, index) => `
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 0.5rem; font-size: 0.85rem;">${sub.date}</td>
                    <td style="padding: 0.5rem; font-size: 0.85rem;">${escapeHtml(sub.email)}</td>
                    <td style="padding: 0.5rem;">
                        <button class="delete-subscriber" data-index="${index}" style="background:none; border:none; color:#d9534f; cursor:pointer;" title="Entfernen">&times;</button>
                    </td>
                </tr>
            `).join('');
        }
    }

    // 5. Render Coupons Table (Admin)
    if (typeof renderAdminCoupons === 'function') {
        renderAdminCoupons();
    }

    // 6. Render Analytics Charts
    renderOrdersChart();

    // 4. Render Stats Table
    const stats = safeJSONParse('druckbau_stats', { views: {}, purchases: {}, youtube_clicks: 0 });
    const statsBody = document.querySelector('#stats-table tbody');
    if (statsBody) {
        // Assuming 'products' is a globally available array or fetched elsewhere
        // For now, let's use a placeholder if products isn't defined in this scope
        const products = window.products || []; // Fallback if products isn't global

        let statsHtml = products.map(p => {
            const buys = stats.purchases[p.id] || 0;
            return `
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 0.5rem;">${p.name}</td>
                    <td style="padding: 0.5rem;">${buys}</td>
                </tr>
            `;
        }).join('');

        // Add YouTube Row
        statsHtml += `
            <tr style="background: rgba(46, 204, 113, 0.1);">
                <td style="padding: 0.5rem; font-weight:bold; color:var(--primary-blue);">YouTube Kanal</td>
                <td style="padding: 0.5rem; font-weight:bold;">${stats.youtube_clicks || 0} Klicks</td>
            </tr>
        `;

        statsBody.innerHTML = statsHtml;
    }
}

// --- Order Logging Hook ---
function logOrder(name, email, orderId, message, couponInfo = null) {
    const newOrder = {
        name,
        email,
        orderId: orderId.toUpperCase(), // Ensure consistency
        message,
        coupon: couponInfo,
        date: new Date().toLocaleString(),
        status: 'Eingegangen' // Default status
    };

    const orders = safeJSONParse('druckbau_orders', []);
    orders.unshift(newOrder);
    localStorage.setItem('druckbau_orders', JSON.stringify(orders));

    triggerAdminRefresh();
    // Also track as a generic purchase/order event
    trackProductPurchase('d'); // 'd' is the ID for custom orders
}

// Global exports
window.initNewsSystem = initNewsSystem;
window.initAdminSystem = initAdminSystem;
window.logOrder = logOrder;
window.trackProductView = trackProductView;
window.trackProductPurchase = trackProductPurchase;
window.trackYouTubeClick = trackYouTubeClick;

