// Add print time to product cards
function addPrintTimeBadges() {
    products.forEach(product => {
        if (product.isCustom) return;

        // Estimate based on typical product dimensions
        const estimatedVolume = {
            'a': 5,    // Fidget Klicker - small
            'b': 50,   // Hundekotbeutelspender - medium
            'c': 150,  // Vase - large
            'e': 30    // Stifthalter - small-medium
        };

        const volume = estimatedVolume[product.id] || 20;
        const printTime = estimatePrintTime(volume);

        // Add badge to product card (will be rendered in renderProducts)
        product.printTime = printTime;
    });
}

// #13 - Coupon System
// coupons moved to top

function initCoupons() {
    const savedCoupons = localStorage.getItem('druckbau_coupons');
    if (savedCoupons) {
        coupons = JSON.parse(savedCoupons);
    } else {
        // Default coupons
        coupons = {
            'NEUKUNDE10': { type: 'percentage', value: 10, expiry: '2026-12-31' },
            'SOMMER2026': { type: 'fixed', value: 5, expiry: '2026-08-31' },
            'TREUE15': { type: 'percentage', value: 15, expiry: '2026-12-31' },
            'WELCOME5': { type: 'fixed', value: 5, expiry: '2026-12-31' }
        };
        saveCoupons();
    }
}

function saveCoupons() {
    localStorage.setItem('druckbau_coupons', JSON.stringify(coupons));
}

// Initialisiere Gutscheine beim Start
initCoupons();

// appliedCoupon moved to top

function applyCoupon() {
    const code = document.getElementById('coupon-input').value.trim().toUpperCase();

    if (!code) {
        alert(t('alert_coupon_invalid'));
        return;
    }

    const coupon = coupons[code];

    if (!coupon) {
        alert(t('alert_coupon_invalid'));
        return;
    }

    // Check expiry
    const today = new Date();
    const expiryDate = new Date(coupon.expiry);

    if (today > expiryDate) {
        alert(t('alert_coupon_expired'));
        return;
    }

    appliedCoupon = { code, ...coupon };
    alert(t('alert_coupon_applied'));
    renderCart(); // Refresh cart with discount
}

function removeCoupon() {
    appliedCoupon = null;
    renderCart();
}

function calculateDiscount(subtotal) {
    if (!appliedCoupon) return 0;

    if (appliedCoupon.type === 'percentage') {
        return subtotal * (appliedCoupon.value / 100);
    } else {
        return appliedCoupon.value;
    }
}

// #16 - Referral Program
function generateReferralLink() {
    // Generate unique referral code based on timestamp
    const referralCode = 'REF' + Date.now().toString(36).toUpperCase();
    localStorage.setItem('druckbau_referral_code', referralCode);

    const baseUrl = window.location.origin + window.location.pathname;
    const referralLink = `${baseUrl}?ref=${referralCode}`;

    document.getElementById('referral-link-input').value = referralLink;

    return referralLink;
}

function copyReferralLink() {
    const input = document.getElementById('referral-link-input');
    input.select();
    document.execCommand('copy');

    alert(t('alert_link_copied'));
}

function checkReferral() {
    const urlParams = new URLSearchParams(window.location.search);
    const refCode = urlParams.get('ref');

    if (refCode) {
        // Track referral
        const referrals = safeJSONParse('druckbau_referrals', []);
        referrals.push({
            code: refCode,
            date: new Date().toISOString(),
            converted: false
        });
        localStorage.setItem('druckbau_referrals', JSON.stringify(referrals));

        // Give 5€ discount to new user
        appliedCoupon = { code: 'REFERRAL5', type: 'fixed', value: 5 };
        alert('Willkommen! Sie erhalten 5€ Rabatt durch eine Empfehlung!');
    }
}

// #23 - Seasonal Offer with Countdown
function initSeasonalOffer() {
    const offerData = safeJSONParse('druckbau_seasonal_offer', null);

    if (!offerData || !offerData.active) {
        document.getElementById('seasonal-offer-banner')?.remove();
        return;
    }

    const banner = document.getElementById('seasonal-offer-banner');
    if (!banner) return;

    document.getElementById('offer-title-text').textContent = offerData.title;
    document.getElementById('offer-description-text').textContent = offerData.description;

    // Countdown timer
    const endDate = new Date(offerData.endDate);

    const updateCountdown = () => {
        const now = new Date();
        const diff = endDate - now;

        if (diff <= 0) {
            banner.remove();
            return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        document.getElementById('countdown-days').textContent = days;
        document.getElementById('countdown-hours').textContent = hours;
        document.getElementById('countdown-minutes').textContent = minutes;
        document.getElementById('countdown-seconds').textContent = seconds;
    };

    updateCountdown();
    setInterval(updateCountdown, 1000);
}

// Admin: Create Seasonal Offer
function createSeasonalOffer() {
    console.log('createSeasonalOffer called');

    try {
        const title = prompt('Angebots-Titel:');
        if (!title) {
            console.log('User cancelled title input');
            return;
        }

        const description = prompt('Beschreibung:');
        if (!description) {
            console.log('User cancelled description input');
            return;
        }

        const days = parseInt(prompt('Wie viele Tage soll das Angebot laufen?'));
        if (!days || isNaN(days)) {
            console.log('Invalid days input:', days);
            alert('Bitte geben Sie eine gültige Anzahl von Tagen ein.');
            return;
        }

        const endDate = new Date();
        endDate.setDate(endDate.getDate() + days);

        const offerData = {
            active: true,
            title,
            description,
            endDate: endDate.toISOString()
        };

        localStorage.setItem('druckbau_seasonal_offer', JSON.stringify(offerData));
        console.log('Offer created:', offerData);
        alert('Angebot erfolgreich erstellt! Die Seite wird neu geladen.');
        location.reload();
    } catch (error) {
        console.error('Error creating seasonal offer:', error);
        alert('Fehler beim Erstellen des Angebots: ' + error.message);
    }
}

// #26 - Push Notifications
function initPushNotifications() {
    if (!('Notification' in window)) {
        console.log('Push notifications not supported');
        return;
    }

    // Check if already granted or denied
    if (Notification.permission === 'granted') {
        return;
    }

    if (Notification.permission === 'denied') {
        return;
    }

    // Show custom prompt after 10 seconds
    setTimeout(() => {
        showNotificationPrompt();
    }, 10000);
}

function showNotificationPrompt() {
    const existingPrompt = document.getElementById('notification-prompt');
    if (existingPrompt) {
        existingPrompt.style.display = 'block';
        return;
    }

    // Create prompt element
    const promptDiv = document.createElement('div');
    promptDiv.id = 'notification-prompt';
    promptDiv.className = 'notification-prompt';
    promptDiv.innerHTML = `
        <h4>${t('notif_title')}</h4>
        <p>${t('notif_desc')}</p>
        <div class="notification-actions">
            <button class="notification-allow">${t('notif_allow')}</button>
            <button class="notification-deny">${t('notif_later')}</button>
        </div>
    `;
    document.body.appendChild(promptDiv);

    // Add event listeners
    promptDiv.querySelector('.notification-allow').addEventListener('click', allowNotifications);
    promptDiv.querySelector('.notification-deny').addEventListener('click', denyNotifications);
}

function allowNotifications() {
    Notification.requestPermission().then(permission => {
        if (permission === 'granted') {
            new Notification('Druckbau', {
                body: t('notif_success_body'),
                icon: 'logo.jpg'
            });
        }
    });
    document.getElementById('notification-prompt').remove();
}

function denyNotifications() {
    document.getElementById('notification-prompt').remove();
}

// Send notification (for order updates)
function sendNotification(title, body) {
    if (Notification.permission === 'granted') {
        new Notification(title, {
            body: body,
            icon: 'logo.jpg',
            badge: 'logo.jpg'
        });
    }
}


// #30 - Enhanced Analytics for Admin Panel
function renderEnhancedAnalytics() {
    const stats = safeJSONParse('druckbau_stats', { views: {}, purchases: {}, youtube_clicks: 0 });
    const orders = safeJSONParse('druckbau_orders', []);
    const subscribers = safeJSONParse('druckbau_subscribers', []);

    // Calculate metrics
    const totalOrders = orders.length;
    const totalRevenue = orders.reduce((sum, order) => {
        // Parse revenue from order if available
        return sum + (order.revenue || 0);
    }, 0);

    const totalViews = Object.values(stats.views).reduce((sum, val) => sum + val, 0);
    const totalPurchases = Object.values(stats.purchases).reduce((sum, val) => sum + val, 0);
    const conversionRate = totalViews > 0 ? ((totalPurchases / totalViews) * 100).toFixed(2) : 0;

    // Render analytics cards
    const analyticsHtml = `
        <div class="analytics-grid">
            <div class="analytics-card">
                <h4>Gesamtumsatz</h4>
                <div class="analytics-value">${totalRevenue.toFixed(2)} €</div>
                <div class="analytics-change positive">+12% vs. letzter Monat</div>
            </div>
            <div class="analytics-card">
                <h4>Bestellungen</h4>
                <div class="analytics-value">${totalOrders}</div>
                <div class="analytics-change positive">+${orders.filter(o => {
        const orderDate = new Date(o.date);
        const weekAgo = new Date();
        weekAgo.setDate(weekAgo.getDate() - 7);
        return orderDate > weekAgo;
    }).length} diese Woche</div>
            </div>
            <div class="analytics-card">
                <h4>Conversion Rate</h4>
                <div class="analytics-value">${conversionRate}%</div>
                <div class="analytics-change">Views → Käufe</div>
            </div>
            <div class="analytics-card">
                <h4>Newsletter Abonnenten</h4>
                <div class="analytics-value">${subscribers.length}</div>
                <div class="analytics-change positive">+${subscribers.filter(s => {
        const subDate = new Date(s.date);
        const weekAgo = new Date();
        weekAgo.setDate(weekAgo.getDate() - 7);
        return subDate > weekAgo;
    }).length} diese Woche</div>
            </div>
        </div>
        
        <div class="chart-container">
            <h4>Bestellungen der letzten 30 Tage</h4>
            <canvas id="orders-chart"></canvas>
        </div>
        
        <div class="analytics-grid" style="margin-top: 2rem;">
            <div class="analytics-card">
                <h4>Beliebtestes Produkt</h4>
                <div class="analytics-value" style="font-size: 1.2rem;">${getMostPopularProduct()}</div>
            </div>
            <div class="analytics-card">
                <h4>Durchschn. Bestellwert</h4>
                <div class="analytics-value">${(totalRevenue / (totalOrders || 1)).toFixed(2)} €</div>
            </div>
            <div class="analytics-card">
                <h4>YouTube Klicks</h4>
                <div class="analytics-value">${stats.youtube_clicks || 0}</div>
            </div>
            <div class="analytics-card">
                <h4>Gutschein-Nutzung</h4>
                <div class="analytics-value">${getCouponUsageCount()}</div>
            </div>
        </div>
    `;

    const container = document.getElementById('enhanced-analytics-container');
    if (container) {
        container.innerHTML = analyticsHtml;
        renderOrdersChart();
    }
}

function getMostPopularProduct() {
    const stats = JSON.parse(localStorage.getItem('druckbau_stats')) || { purchases: {} };
    let maxPurchases = 0;
    let popularProduct = 'N/A';

    Object.entries(stats.purchases).forEach(([productId, count]) => {
        if (count > maxPurchases) {
            maxPurchases = count;
            const product = products.find(p => p.id === productId);
            popularProduct = product ? product.name : productId;
        }
    });

    return popularProduct;
}

function getCouponUsageCount() {
    const couponUsage = safeJSONParse('druckbau_coupon_usage', []);
    return couponUsage.length;
}

// Gutschein-Verwaltung Funktionen
function renderAdminCoupons() {
    const tbody = document.querySelector('#admin-coupons-table tbody');
    if (!tbody) return;

    if (Object.keys(coupons).length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="padding:1rem; text-align:center;">Keine Gutscheine vorhanden.</td></tr>';
    } else {
        tbody.innerHTML = Object.entries(coupons).map(([code, data]) => `
            <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 0.5rem; font-weight: bold;">${code}</td>
                <td style="padding: 0.5rem; font-size: 0.85rem;">${data.type === 'percentage' ? 'Prozent' : 'Festbetrag'}</td>
                <td style="padding: 0.5rem;">${data.value}${data.type === 'percentage' ? '%' : '€'}</td>
                <td style="padding: 0.5rem; font-size: 0.85rem;">${formatDisplayDate(data.expiry)}</td>
                <td style="padding: 0.5rem;">
                    <button data-code="${code}" style="background:#d9534f; border:none; color:white; padding: 4px 8px; border-radius:4px; cursor:pointer; font-size: 0.8rem;" title="Löschen">Löschen</button>
                </td>
            </tr>
        `).join('');
    }
}

function deleteCoupon(code) {
    if (confirm(`Gutschein "${code}" wirklich löschen?`)) {
        delete coupons[code];
        saveCoupons();
        renderAdminCoupons();
        alert(`Gutschein "${code}" gelöscht.`);
    }
}

function addAdminCoupon() {
    const codeInput = document.getElementById('admin-coupon-code');
    const typeSelect = document.getElementById('admin-coupon-type');
    const valueInput = document.getElementById('admin-coupon-value');
    const expiryInput = document.getElementById('admin-coupon-expiry');

    const code = codeInput.value.trim().toUpperCase();
    const type = typeSelect.value;
    const value = parseFloat(valueInput.value);
    const expiryRaw = expiryInput.value.trim();

    if (!code || isNaN(value) || !expiryRaw) {
        alert("Bitte füllen Sie alle Felder korrekt aus.");
        return;
    }

    // Datum validieren und umwandeln (TT.MM.JJJJ -> YYYY-MM-DD)
    const dateParts = expiryRaw.split('.');
    if (dateParts.length !== 3) {
        alert("Bitte geben Sie das Datum im Format TT.MM.JJJJ an.");
        return;
    }
    const expiry = `${dateParts[2]}-${dateParts[1]}-${dateParts[0]}`;
    if (isNaN(new Date(expiry).getTime())) {
        alert("Ungültiges Datum.");
        return;
    }

    if (coupons[code]) {
        if (!confirm(`Gutschein "${code}" existiert bereits. Möchten Sie ihn überschreiben?`)) {
            return;
        }
    }

    coupons[code] = { type, value, expiry };
    saveCoupons();

    // UI zurücksetzen
    codeInput.value = '';
    valueInput.value = '';
    expiryInput.value = '';

    renderAdminCoupons();
    alert(`Gutschein "${code}" gespeichert.`);
}

function formatDisplayDate(isoDate) {
    if (!isoDate) return '-';
    const parts = isoDate.split('-');
    if (parts.length === 3) {
        return `${parts[2]}.${parts[1]}.${parts[0]}`;
    }
    return isoDate;
}

window.deleteCoupon = deleteCoupon;

// Wishlist Logic
function toggleWishlist(productId) {
    const index = wishlist.indexOf(productId);
    if (index === -1) {
        wishlist.push(productId);
        showNotification(`${products.find(p => p.id === productId).name} zur Wunschliste hinzugefügt!`, 'success');
    } else {
        wishlist.splice(index, 1);
        showNotification(`${products.find(p => p.id === productId).name} von der Wunschliste entfernt.`, 'info');
    }
    saveWishlistToStorage();
    renderProducts();
    updateWishlistIcon();
    if (document.getElementById('wishlist').style.display === 'block' || document.getElementById('wishlist').classList.contains('active')) {
        renderWishlist();
    }
}

function loadWishlistFromStorage() {
    const saved = localStorage.getItem('druckbau_wishlist');
    if (saved) {
        wishlist = JSON.parse(saved);
    }
}

function saveWishlistToStorage() {
    localStorage.setItem('druckbau_wishlist', JSON.stringify(wishlist));
}

function updateWishlistIcon() {
    const count = document.getElementById('wishlist-count');
    if (count) {
        count.textContent = wishlist.length;
    }
}

function renderWishlist() {
    const container = document.getElementById('wishlist-items');
    if (!container) return;

    if (wishlist.length === 0) {
        container.innerHTML = `
            <div class="wishlist-empty">
                <h2>Ihre Wunschliste ist leer</h2>
                <p>Entdecken Sie unsere <a href="#" class="nav-link" data-target="products">Produkte</a> und markieren Sie Ihre Favoriten!</p>
            </div>
        `;
        return;
    }

    const wishlistProducts = wishlist.map(id => products.find(p => p.id === id)).filter(p => p);

    container.innerHTML = wishlistProducts.map(product => `
        <div class="cart-item">
            <div class="cart-item-details">
                <h4>${product.name}</h4>
                <p class="cart-item-info">${product.price > 0 ? formatCurrency(product.price) : 'Individueller Preis'}</p>
            </div>
            <div style="display: flex; gap: 1rem; align-items: center;">
                <button class="contact-btn wishlist-add-to-cart-btn" data-product-id="${product.id}" style="padding: 0.5rem 1rem; font-size: 0.85rem;">
                    In den Warenkorb
                </button>
                <button class="remove-btn wishlist-remove-btn" data-product-id="${product.id}" title="Entfernen">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                    </svg>
                </button>
            </div>
        </div>
    `).join('');

    // Add event listeners for wishlist buttons
    container.querySelectorAll('.wishlist-add-to-cart-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const productId = btn.getAttribute('data-product-id');
            addToCartFromWishlist(productId);
        });
    });

    container.querySelectorAll('.wishlist-remove-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const productId = btn.getAttribute('data-product-id');
            toggleWishlist(productId);
        });
    });

    // Re-attach nav-link listeners within wishlist
    container.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = link.getAttribute('data-target');
            if (targetId) showSection(targetId);
        });
    });
}

function addToCartFromWishlist(productId) {
    const product = products.find(p => p.id === productId);
    if (!product) return;

    if (product.isCustom) {
        showInfo('Bitte konfigurieren Sie die Auftragsarbeit auf der Produktseite');
        showSection('products');
        return;
    }

    // Add with default settings
    const defaultColor = colors[0];
    cart.push({
        id: productId,
        name: product.name,
        price: product.price,
        qty: 1,
        color: defaultColor.value,
        colorName: defaultColor.name,
        isCustom: false
    });

    saveCartToStorage();
    updateCartIcon();
    showSuccess(`${product.name} wurde zum Warenkorb hinzugefügt`);
    trackProductPurchase(productId);
}

