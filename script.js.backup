function renderOrdersChart() {
    const canvas = document.getElementById('admin-orders-chart');
    const rangeSelect = document.getElementById('admin-chart-range');
    if (!canvas) return;

    const orders = safeJSONParse('druckbau_orders', []);
    const range = rangeSelect ? rangeSelect.value : '1w';

    let daysToDisplay = 7;
    let stepSize = 1;

    if (range === 'day') daysToDisplay = 1;
    else if (range === '1w') daysToDisplay = 7;
    else if (range === '1m') daysToDisplay = 30;
    else if (range === '5m') daysToDisplay = 150;
    else if (range === 'all') {
        if (orders.length > 0) {
            const firstDate = new Date(orders[orders.length - 1].date.split('.').reverse().join('-'));
            const diffTime = Math.abs(new Date() - firstDate);
            daysToDisplay = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
        } else {
            daysToDisplay = 7;
        }
    }

    const labels = [];
    const dataPoints = [];

    for (let i = daysToDisplay - 1; i >= 0; i--) {
        const d = new Date();
        d.setDate(d.getDate() - i);
        const dateStr = d.toLocaleDateString('de-DE');
        labels.push(dateStr);
        dataPoints.push(orders.filter(o => o.date.startsWith(dateStr)).length);
    }

    // Adjust density for large ranges
    let finalLabels = labels;
    let finalData = dataPoints;
    if (daysToDisplay > 31) {
        // Show only every 7th label for large ranges
        finalLabels = labels.map((l, i) => (i % 7 === 0 || i === labels.length - 1) ? l : '');
    }

    // Destroy existing chart if any
    if (window.myAdminChart) {
        window.myAdminChart.destroy();
    }

    // Create new chart
    window.myAdminChart = new Chart(canvas, {
        type: 'line',
        data: {
            labels: finalLabels,
            datasets: [{
                label: 'Bestellungen',
                data: finalData,
                borderColor: '#2563eb',
                backgroundColor: 'rgba(37, 99, 235, 0.2)',
                borderWidth: 2,
                fill: true,
                tension: 0.3,
                pointRadius: daysToDisplay > 30 ? 0 : 3
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1,
                        precision: 0
                    }
                },
                x: {
                    grid: { display: false }
                }
            }
        }
    });
}

function exportOrdersToCSV() {
    const orders = safeJSONParse('druckbau_orders', []);
    if (orders.length === 0) {
        alert("Keine Bestellungen zum Exportieren vorhanden.");
        return;
    }

    // Define CSV header
    const headers = ['Datum', 'Name', 'Bestell-ID', 'Email', 'Nachricht', 'Gutschein', 'Rabatt', 'Status'];

    // Define rows
    const rows = orders.map(o => [
        o.date,
        `"${o.name}"`,
        o.orderId,
        o.email,
        `"${o.message.replace(/"/g, '""')}"`,
        o.coupon ? o.coupon.code : '-',
        o.coupon ? o.coupon.discount : 0,
        o.status || 'Eingegangen'
    ]);

    // Create CSV string
    const csvContent = [
        headers.join(','),
        ...rows.map(r => r.join(','))
    ].join('\n');

    // Create download link
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.setAttribute('href', url);
    link.setAttribute('download', `druckbau_bestellungen_${new Date().toISOString().split('T')[0]}.csv`);
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
}

